#!/usr/bin/env bash
# devctl — Green Earth local development environment (issue api#268).
#
# Orchestrates the docker-compose stack in this directory. The key sequencing
# it owns: es-init must complete (minting ES API keys into .runtime/) before
# the api starts, and seeding runs rebase -> megastream ingest -> likes.
#
# Layout assumption: this repo (internal-tools) is checked out next to its
# sibling repos (api, ingex, ...) under one parent directory, like the
# greenearth-social monorepo checkout. Override with GE_DEV_REPO_ROOT.
set -euo pipefail

DEVENV_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Optional local overrides (ports, ES heap, ...). Gitignored.
if [[ -f "$DEVENV_DIR/devenv.local.env" ]]; then
  set -a
  # shellcheck source=/dev/null
  source "$DEVENV_DIR/devenv.local.env"
  set +a
fi

export GE_DEV_REPO_ROOT="${GE_DEV_REPO_ROOT:-$(cd "$DEVENV_DIR/../.." && pwd)}"
FIXTURE_REPO="${GE_DEV_FIXTURE_REPO:-greenearth-social/internal-tools}"
FIXTURE_ASSET="ge-dev-fixture.tar"
MODELS_ASSET="ge-dev-models.tar"
# Pinned, unlike the fixture, which tracks the newest release. Model artifacts
# and seeded post embeddings have to agree — the towers only make sense over
# embeddings produced by the matching post tower — so everyone runs the same
# models until someone deliberately moves this. The tag names the two training
# runs in the bundle (two-tower, ranker); models/publish_models.sh derives it
# from the artifacts and prints what to set here.
MODELS_TAG="${GE_DEV_MODELS_TAG:-models-1bf1ea3c-177899dd}"
API_PORT="${GE_DEV_PORT_API:-8300}"
ES_PORT="${GE_DEV_PORT_ES:-9201}"
FIRESTORE_PORT="${GE_DEV_PORT_FIRESTORE:-8080}"
AUTH_PORT="${GE_DEV_PORT_FIREBASE_AUTH:-9099}"
FUNCTIONS_PORT="${GE_DEV_PORT_FUNCTIONS:-5001}"
FIREBASE_UI_PORT="${GE_DEV_PORT_FIREBASE_UI:-4000}"
FRONTEND_PORT="${GE_DEV_PORT_FRONTEND:-3000}"

compose() {
  docker compose -f "$DEVENV_DIR/docker-compose.yml" --project-directory "$DEVENV_DIR" "$@"
}

die() {
  echo "devctl: $*" >&2
  exit 1
}

# ---------------------------------------------------------------------------

check_docker() {
  command -v docker >/dev/null || die "docker is required (https://docs.docker.com/get-docker/)"
  docker info >/dev/null 2>&1 || die "docker daemon isn't running"
  docker compose version >/dev/null 2>&1 || die "docker compose v2 is required"
}

check_repos() {
  local missing=0
  local repo
  for repo in api ingex frontend inference-service; do
    if [[ ! -e "$GE_DEV_REPO_ROOT/$repo/.git" ]]; then
      echo "devctl: required repo missing: $GE_DEV_REPO_ROOT/$repo" >&2
      echo "        clone it: git clone git@github.com:greenearth-social/$repo.git \"$GE_DEV_REPO_ROOT/$repo\"" >&2
      missing=1
    fi
  done
  [[ $missing -eq 0 ]] || die "missing required repos (or set GE_DEV_REPO_ROOT to the directory that contains them)"
  # Only needed to retrain or republish models, not to run the environment.
  [[ -e "$GE_DEV_REPO_ROOT/engagement-prediction/.git" ]] ||
    echo "devctl: note: optional repo not checked out: $GE_DEV_REPO_ROOT/engagement-prediction" >&2
}

ensure_runtime() {
  mkdir -p "$DEVENV_DIR/.runtime/seed" "$DEVENV_DIR/models/data"
  # compose env_file entries must exist before any `compose` invocation.
  touch "$DEVENV_DIR/.runtime/es_key_ro.env" \
    "$DEVENV_DIR/.runtime/es_key_rw.env" \
    "$DEVENV_DIR/.runtime/probe.env" \
    "$DEVENV_DIR/models/data/models.env"
}

# --- live services ----------------------------------------------------------
# Everything runs locally by default. `--live <svc>[,<svc>]` (or GE_DEV_LIVE in
# devenv.local.env) points individual dependencies at deployed ones instead,
# for the cases where the local stand-in can't reproduce what you're chasing.
#
#   devctl up --live inference,perspective
#   devctl up --live es --live-env prod
#
# `up` is the only command that decides: it reads the flag, falling back to
# devenv.local.env, and records the result in .runtime/. Every other command
# reads that record, so `seed` and `status` act on the environment that is
# actually running. Deciding this way means a bare `devctl up` always returns
# to all-local, instead of quietly inheriting a live service from hours ago.

LIVE_STATE="$DEVENV_DIR/.runtime/live.env"
LIVE_CONFIGURED="${GE_DEV_LIVE:-}"
LIVE_ENV_CONFIGURED="${GE_DEV_LIVE_ENV:-stage}"
if [[ -f "$LIVE_STATE" ]]; then
  set -a
  # shellcheck source=/dev/null
  source "$LIVE_STATE"
  set +a
fi
GE_DEV_LIVE="${GE_DEV_LIVE:-}"
GE_DEV_LIVE_ENV="${GE_DEV_LIVE_ENV:-stage}"

LIVE_SERVICES="es inference perspective"

live_has() {
  case ",${GE_DEV_LIVE}," in
  *",$1,"*) return 0 ;;
  *) return 1 ;;
  esac
}

# Where each live service actually is, and which variable holds its key. Kept
# here so nobody has to remember a Cloud Run hostname to use one.
live_url() {
  case "$1:$GE_DEV_LIVE_ENV" in
  inference:stage) echo "https://inference-stage.greenearth.social" ;;
  inference:prod) echo "https://inference.greenearth.social" ;;
  perspective:*) echo "https://commentanalyzer.googleapis.com" ;;
  # Reached through the tunnel `devctl tunnel` opens: the cluster's ES sits
  # behind an internal load balancer, so there's no address a container could
  # dial directly. host.docker.internal is the host running kubectl.
  es:*) echo "https://host.docker.internal:${GE_DEV_ES_TUNNEL_PORT:-9200}" ;;
  esac
}

live_key_var() {
  case "$1" in
  inference) echo GE_DEV_INFERENCE_API_KEY ;;
  perspective) echo GE_PERSPECTIVE_API_KEY ;;
  es) echo GE_DEV_ES_API_KEY ;;
  esac
}

# Turns GE_DEV_LIVE into the GE_DEV_*_URL variables docker-compose.yml reads,
# after checking that each service named there is real and has a key. Failing
# here beats failing as a 401 inside a container ten seconds later.
resolve_live() {
  # Environment first: a typo'd --live-env would otherwise be reported as
  # whichever key happened to be missing, which reads as an unrelated problem.
  case "$GE_DEV_LIVE_ENV" in
  stage | prod) ;;
  *) die "--live-env must be stage or prod (got: $GE_DEV_LIVE_ENV)" ;;
  esac

  local svc
  for svc in ${GE_DEV_LIVE//,/ }; do
    [[ " $LIVE_SERVICES " == *" $svc "* ]] ||
      die "unknown live service: $svc (choose from: $LIVE_SERVICES)"
    local key_var
    key_var="$(live_key_var "$svc")"
    [[ -n "${!key_var:-}" ]] ||
      die "--live $svc needs $key_var — set it in devenv.local.env"
  done

  # GE_DEV_INFERENCE_URL doubles as the escape hatch for an inference service
  # that isn't one of ours — one you're running by hand, say. Setting it
  # directly skips the lookup above but still routes the api away from local.
  if live_has inference; then
    export GE_DEV_INFERENCE_URL="${GE_DEV_INFERENCE_URL:-$(live_url inference)}"
  fi
  live_has perspective && export GE_DEV_PERSPECTIVE_HOST="$(live_url perspective)"
  live_has es && export GE_DEV_ES_URL="$(live_url es)"

  if [[ "$GE_DEV_LIVE_ENV" == "prod" && -n "$GE_DEV_LIVE" ]]; then
    echo "devctl: WARNING — using PROD services: $GE_DEV_LIVE" >&2
  fi
  return 0
}

record_live_choice() {
  cat >"$LIVE_STATE" <<EOF
GE_DEV_LIVE=$GE_DEV_LIVE
GE_DEV_LIVE_ENV=$GE_DEV_LIVE_ENV
EOF
}

# Reach each live service once, from the host, before anything depends on it.
# A bad key or a closed tunnel otherwise shows up as feeds that 500 with the
# reason buried in a container log.
#
# host.docker.internal is how a *container* names the host, and it doesn't
# resolve on the host itself — so probing it verbatim would report every tunnel
# as closed. Since that name only ever appears in the tunnel URL, and a tunnel
# is a host-local listener, 127.0.0.1 is the same endpoint seen from here.
probe_url() {
  echo "${1//host.docker.internal/127.0.0.1}"
}

preflight_live() {
  local code
  if live_has inference; then
    code="$(curl -sk -o /dev/null -w '%{http_code}' --max-time 15 \
      -H "X-API-Key: ${GE_DEV_INFERENCE_API_KEY}" \
      "$(probe_url "$GE_DEV_INFERENCE_URL")/ready" 2>/dev/null || true)"
    case "$code" in
    200) echo "devctl: live inference OK ($GE_DEV_INFERENCE_URL)" ;;
    401 | 403) die "live inference rejected GE_DEV_INFERENCE_API_KEY (HTTP $code)" ;;
    000) die "live inference unreachable at $GE_DEV_INFERENCE_URL" ;;
    *) die "live inference returned HTTP $code from $GE_DEV_INFERENCE_URL/ready" ;;
    esac
  fi
  if live_has es; then
    code="$(curl -sk -o /dev/null -w '%{http_code}' --max-time 15 \
      -H "Authorization: ApiKey ${GE_DEV_ES_API_KEY}" \
      "$(probe_url "$GE_DEV_ES_URL")/_cluster/health" 2>/dev/null || true)"
    case "$code" in
    200) echo "devctl: live Elasticsearch OK ($GE_DEV_ES_URL)" ;;
    401 | 403) die "live Elasticsearch rejected GE_DEV_ES_API_KEY (HTTP $code)" ;;
    000) die "live Elasticsearch unreachable at $GE_DEV_ES_URL — is the tunnel open?
        devctl tunnel $GE_DEV_LIVE_ENV" ;;
    *) die "live Elasticsearch returned HTTP $code" ;;
    esac
  fi
  # Perspective isn't probed: every call costs quota, and a bad key surfaces
  # immediately as a failed feed rather than something subtle.
}

# The api reads its ES endpoint from the compose `environment` block rather
# than an env_file, so that it can be pointed at a deployed cluster (an
# `environment` entry always wins over env_file, so the file can't be the
# fallback). That makes supplying the local key devctl's job.
export_api_es_env() {
  if [[ -z "${GE_DEV_ES_API_KEY:-}" ]]; then
    GE_DEV_ES_API_KEY="$(sed -n 's/^GE_ELASTICSEARCH_API_KEY=//p' \
      "$DEVENV_DIR/.runtime/es_key_ro.env")"
    [[ -n "$GE_DEV_ES_API_KEY" ]] ||
      die "no Elasticsearch key in .runtime/es_key_ro.env — run: devctl up"
  fi
  export GE_DEV_ES_API_KEY
}

have_models() {
  [[ -f "$DEVENV_DIR/models/data/manifest.json" ]]
}

models_tag() {
  python3 -c "
import json
print(json.load(open('$DEVENV_DIR/models/data/manifest.json'))['tag'])"
}

models_hint() {
  cat >&2 <<EOF

No model artifacts found in devenv/models/data/. Get them:

  devctl fetch-models

That downloads the pinned release ($MODELS_TAG, ~33MB) — no account or
credentials needed. \`devctl setup\` does it for you.
EOF
}

# Nothing to compare until both halves are present; models/check_compat.py
# explains why this matters.
check_model_fixture_compat() {
  have_models && have_fixtures || return 0
  python3 "$DEVENV_DIR/models/check_compat.py" \
    "$DEVENV_DIR/models/data/manifest.json" \
    "$DEVENV_DIR/fixtures/data/manifest.json" || exit 1
}

es_curl() {
  local path="$1"
  shift
  local key
  key="$(sed -n 's/^GE_ELASTICSEARCH_API_KEY=//p' "$DEVENV_DIR/.runtime/es_key_ro.env")"
  [[ -n "$key" ]] || die "no ES key yet — run: devctl up"
  curl -s -H "Authorization: ApiKey $key" "http://127.0.0.1:${ES_PORT}${path}" "$@"
}

have_fixtures() {
  [[ -f "$DEVENV_DIR/fixtures/data/manifest.json" ]]
}

# Download a release asset and replace `dest` with its contents. Deliberately
# curl against the public releases API rather than the gh CLI: both these repos
# are public, so a fresh clone can fetch what it needs with no GitHub account,
# no auth, and no extra tooling installed.
fetch_release_asset() {
  local tag="$1" asset="$2" dest="$3" size="$4"
  command -v curl >/dev/null || die "curl is required to download $asset"

  local workdir
  workdir="$(mktemp -d)"
  # shellcheck disable=SC2064  # expand workdir now, not at trap time
  trap "rm -rf '$workdir'" RETURN

  echo "devctl: downloading $tag ($size)..."
  curl -fL --progress-bar \
    "https://github.com/$FIXTURE_REPO/releases/download/$tag/$asset" \
    -o "$workdir/$asset" ||
    die "download failed — check network access to github.com, and that $tag exists in $FIXTURE_REPO"

  # Extract into a scratch directory first so a torn archive can't leave the
  # destination holding half of one release and half of another.
  mkdir -p "$workdir/x"
  tar -xf "$workdir/$asset" -C "$workdir/x" || die "$tag: archive is unreadable"
  rm -rf "$dest"
  mkdir -p "$(dirname "$dest")"
  mv "$workdir/x" "$dest"
}

fixtures_hint() {
  cat >&2 <<EOF

No fixture set found in devenv/fixtures/data/. Get one:

  # Download the published sample (what you usually want):
  devctl fetch-fixture

  # Or generate your own from real data (needs read-only prod ES,
  # port-forwarded — see README):
  python3 $DEVENV_DIR/fixtures/generate_sample.py --source prod-es

  # Or without any credentials (uses ingex's checked-in sample files
  # and synthesizes the like graph):
  python3 $DEVENV_DIR/fixtures/generate_sample.py --source megastream-files

Then run: devctl seed
EOF
}

cmd_fetch_fixture() {
  command -v curl >/dev/null || die "curl is required to download fixtures"
  command -v python3 >/dev/null || die "python3 is required to download fixtures"

  # Newest fixture release, unlike the models, which are pinned — a fixture is
  # a sample of Bluesky rather than something the rest of the stack has to
  # agree with.
  local tag
  tag="$(curl -fsSL "https://api.github.com/repos/$FIXTURE_REPO/releases?per_page=50" 2>/dev/null |
    python3 -c "
import json, sys
try:
    releases = json.load(sys.stdin)
except json.JSONDecodeError:
    sys.exit(0)
tags = [r['tag_name'] for r in releases
        if isinstance(r, dict) and r.get('tag_name', '').startswith('fixture-')]
print(tags[0] if tags else '')
" 2>/dev/null || true)"
  if [[ -z "$tag" ]]; then
    die "no fixture release found in $FIXTURE_REPO (or GitHub is unreachable / rate-limiting).
Generate a set locally instead — see: devctl help"
  fi

  # Replace rather than merge: mixing chunks from different samples would give
  # the seed an inconsistent post/like graph.
  fetch_release_asset "$tag" "$FIXTURE_ASSET" "$DEVENV_DIR/fixtures/data" "~170MB"

  python3 - "$DEVENV_DIR/fixtures/data/manifest.json" <<'PY'
import json, sys, pathlib
m = json.loads(pathlib.Path(sys.argv[1]).read_text())
c = m["counts"]
print(f"devctl: fetched {c['posts']:,} posts / {c['likes']:,} likes "
      f"(window ends {m['window_end']}, source {m['source']})")
PY
  echo "Next: devctl up && devctl seed"
}

cmd_fetch_models() {
  # Same public-release channel as the fixture, and for the same reason: a
  # fresh clone gets working trained models with no Google account, no GCS
  # credentials and no ClearML.
  # Replace rather than merge: the serving manifests name specific weight
  # files, and a half-updated directory would load one release's towers
  # against another's author index map.
  fetch_release_asset "$MODELS_TAG" "$MODELS_ASSET" "$DEVENV_DIR/models/data" "~33MB"

  python3 - "$DEVENV_DIR/models/data/manifest.json" <<'PY'
import json, sys, pathlib
m = json.loads(pathlib.Path(sys.argv[1]).read_text())
print(f"devctl: fetched models {m['tag']} — {m['content_embedding_model']} "
      f"({m['content_embedding_dims']}d) in, {m['output_embedding_dim']}d out")
PY
  check_model_fixture_compat
  echo "Next: devctl up && devctl seed"
}

# ---------------------------------------------------------------------------

cmd_setup() {
  check_docker
  check_repos
  ensure_runtime
  echo "devctl: pulling and building images (first run takes a few minutes)..."
  compose --profile tools build es-init api inference firebase frontend
  compose --profile tools pull elasticsearch perspective-stub dev-auth seed-rebase seed-megastream --ignore-buildable

  have_models || cmd_fetch_models

  # Install inference-service's dependencies now rather than on first `up`.
  # torch is a few hundred MB; doing it here, where a wait is expected, keeps
  # `up` from looking hung the first time. It also keeps `up` runnable
  # offline, which is true of everything else here once setup has run.
  echo "devctl: preparing inference-service dependencies (one time, ~1 min)..."
  compose run --rm --no-deps inference bash /inference/start.sh --install-only ||
    die "failed to install inference-service dependencies"

  echo "devctl: setup complete."
  have_fixtures || fixtures_hint
  echo "Next: devctl up && devctl seed"
}

cmd_up() {
  local jetstream=0
  # Start from what's configured, not from what the last `up` recorded, so this
  # command fully determines the result.
  GE_DEV_LIVE="$LIVE_CONFIGURED"
  GE_DEV_LIVE_ENV="$LIVE_ENV_CONFIGURED"
  while [[ $# -gt 0 ]]; do
    case "$1" in
    --with-jetstream)
      jetstream=1
      shift
      ;;
    --live)
      GE_DEV_LIVE="$2"
      shift 2
      ;;
    --live-env)
      GE_DEV_LIVE_ENV="$2"
      shift 2
      ;;
    *) die "unknown argument to up: $1 (try: devctl help)" ;;
    esac
  done

  check_docker
  check_repos
  ensure_runtime
  resolve_live
  record_live_choice

  # One list, built from what's staying local. A live service's container isn't
  # just skipped but stopped: it's still a defined service, so --remove-orphans
  # leaves it running, and it would go on answering nothing.
  local local_services=(elasticsearch firebase dev-auth)
  local svc
  for svc in inference perspective-stub; do
    local name="${svc%-stub}"
    if live_has "$name"; then
      compose stop "$svc" >/dev/null 2>&1 || true
    else
      local_services+=("$svc")
    fi
  done

  if ! live_has inference; then
    have_models || { models_hint; exit 1; }
    check_model_fixture_compat
  fi
  preflight_live

  # --remove-orphans clears containers for services this file no longer
  # defines — e.g. the standalone `firestore` emulator that the Firebase
  # suite replaced, which would otherwise linger holding its old port.
  # --wait because the api no longer depends_on the swappable ones, so this is
  # what guarantees they're serving before it starts.
  compose up -d --remove-orphans --wait "${local_services[@]}"
  echo "devctl: initializing Elasticsearch (templates, indexes, API keys)..."
  compose run --rm es-init
  export_api_es_env
  compose up -d api frontend
  cat <<EOF
devctl: environment is up.
  frontend      http://127.0.0.1:${FRONTEND_PORT}    (first start installs deps; watch: devctl logs -t frontend)
  api           http://127.0.0.1:${API_PORT}    (first start installs deps; watch: devctl logs -t api)
  elasticsearch http://127.0.0.1:${ES_PORT}    (user elastic / ${GE_DEV_ES_PASSWORD:-ge-dev-elastic})
  firestore     127.0.0.1:${FIRESTORE_PORT}    (emulator, from the frontend checkout)
  firebase auth 127.0.0.1:${AUTH_PORT}
  functions     127.0.0.1:${FUNCTIONS_PORT}
  emulator UI   http://127.0.0.1:${FIREBASE_UI_PORT}    (browse Firestore data, auth users, function logs)
EOF
  if live_has inference; then
    echo "  inference     LIVE $GE_DEV_INFERENCE_URL"
  else
    echo "  inference     $(models_tag)    (watch: devctl logs -t inference)"
  fi
  live_has es && echo "  ** the api is reading LIVE Elasticsearch: $GE_DEV_ES_URL"
  live_has perspective && echo "  ** the api is calling the LIVE Perspective API"
  if [[ $jetstream -eq 1 ]]; then
    compose --profile jetstream up -d jetstream-ingest
    echo "  jetstream     streaming live likes from the public firehose (needs internet)"
  fi
  # The posts alias doesn't exist until the first seed (the ingest binary
  # creates it, as in prod) — treat a missing alias like an empty index.
  local post_count
  post_count="$(es_curl /posts/_count | sed -n 's/.*"count":\([0-9]*\).*/\1/p')"
  if [[ -z "$post_count" || "$post_count" == "0" ]]; then
    if have_fixtures; then
      echo "Elasticsearch is empty — run: devctl seed"
    else
      fixtures_hint
    fi
  fi
}

cmd_seed() {
  check_docker
  ensure_runtime
  have_fixtures || { fixtures_hint; exit 1; }
  local rw_key
  rw_key="$(sed -n 's/^GE_ELASTICSEARCH_API_KEY=//p' "$DEVENV_DIR/.runtime/es_key_rw.env")"
  [[ -n "$rw_key" ]] || die "no ES key yet — run: devctl up"
  check_model_fixture_compat

  resolve_live

  # Seeding always writes to the *local* cluster — the seed services address it
  # directly and ignore GE_DEV_ES_URL, so there is no way for this to touch a
  # deployed one. Worth saying out loud, because the api is meanwhile reading
  # somewhere else and the data about to be loaded won't show up in a feed.
  if live_has es; then
    echo "devctl: note — seeding local Elasticsearch, but the api is reading" >&2
    echo "        $GE_DEV_ES_URL, so this data won't appear in feeds." >&2
  fi

  # megastream_ingest computes each post's ge_post_embedding by calling the
  # inference service, so the seed is only meaningful once that service has
  # actually loaded its models. seed-megastream can't depend_on it — whether it
  # runs at all is decided here, not in the compose file — so wait explicitly.
  # --wait blocks on the healthcheck, which probes /ready, not /health.
  if ! live_has inference; then
    echo "devctl: waiting for inference to be ready..."
    compose up -d --wait inference ||
      die "inference never became ready — see: devctl logs inference"
  fi

  echo "devctl: wiping previously seeded data..."
  compose run --rm seed-wipe
  echo "devctl: rebasing fixture timestamps..."
  compose run --rm seed-rebase
  echo "devctl: ingesting posts via megastream_ingest (first run compiles the Go binary)..."
  compose run --rm seed-megastream
  echo "devctl: loading likes and like counts..."
  compose run --rm seed-likes
  local persona api_running=0
  persona="$(sed -n 's/^GE_PROBE_USER_DID=//p' "$DEVENV_DIR/.runtime/probe.env")"
  # Restart the api so it picks up the new persona from .runtime/probe.env —
  # but only if it was already running, so `seed` never starts a service the
  # developer deliberately stopped.
  if compose ps --status running api | grep -q api; then
    export_api_es_env
    compose up -d --force-recreate api
    api_running=1
  fi

  echo "devctl: seed complete (persona: ${persona:-unset})."
  if [[ $api_running -eq 1 ]]; then
    echo "Try a feed:"
    echo "  devctl feed"
  else
    # Don't suggest a feed request with nothing to serve it.
    echo "The api isn't running — start it with: devctl up"
  fi
}

cmd_feed() {
  # Terminal feed viewer (issue #285): request getFeedSkeleton as the seeded
  # persona, hydrate each post from this environment's Elasticsearch, and print
  # the feed. Runs inside the api container, which already has every input the
  # viewer needs — the dev-session secret (so the api runs the full signed-in
  # path and records a snapshot for the transparency UI), the persona DID, the
  # ES read key, and the Firestore config for the per-post pipeline detail.
  #
  #   devctl feed
  #   devctl feed your-feed --user did:plc:... --limit 50 --pages 2
  #   devctl feed --json                 # raw getFeedSkeleton, the old output
  #
  # All arguments pass through to scripts/feed_view.py (feed defaults to
  # your-feed). See feed_view.py --help for the full flag set.
  compose ps --status running api | grep -q api ||
    die "the api isn't running — start it with: devctl up"
  # Give the viewer a TTY when stdout is a terminal so rich colorizes; drop it
  # (-T) when piped or redirected, where TTY allocation would fail. The
  # "${arr[@]+...}" guard keeps an empty array from tripping `set -u` on
  # macOS's bash 3.2.
  local tty=()
  [[ -t 1 ]] || tty=(-T)
  compose exec ${tty[@]+"${tty[@]}"} -e PIPENV_VERBOSITY=-1 api \
    pipenv run python scripts/feed_view.py "$@"
}

cmd_tunnel() {
  # `--live es` needs one of these open: the cluster sits behind an internal
  # load balancer with no address a container can dial. Runs in the foreground
  # and restarts itself, because kubectl port-forward drops connections
  # routinely and a silently dead tunnel looks like a broken environment.
  local env="${1:-$GE_DEV_LIVE_ENV}"
  case "$env" in
  stage | prod) ;;
  *) die "usage: devctl tunnel [stage|prod]" ;;
  esac

  command -v kubectl >/dev/null || die "kubectl is required for devctl tunnel"
  local ns="${GE_DEV_ES_NAMESPACE:-greenearth-$env}"
  local svc="${GE_DEV_ES_SERVICE:-svc/greenearth-es-internal-lb}"
  local port="${GE_DEV_ES_TUNNEL_PORT:-9200}"

  echo "devctl: tunneling $ns/$svc to localhost:$port (ctrl-c to stop)"
  echo "        then, in another shell: devctl up --live es --live-env $env"
  while true; do
    kubectl port-forward "$svc" "${port}:9200" -n "$ns" || true
    echo "devctl: tunnel dropped, reconnecting..." >&2
    sleep 2
  done
}

cmd_login() {
  # Signing in normally means completing Bluesky OAuth, which needs private
  # keys a credential-free environment doesn't have. The Auth emulator accepts
  # unsigned custom tokens, so we mint one for the seeded persona and hand it
  # to the app's own #/auth/finish route — the same entry point the real OAuth
  # callback redirects to. See firebase/mint_token.py.
  local persona token
  persona="${1:-$(sed -n 's/^GE_PROBE_USER_DID=//p' "$DEVENV_DIR/.runtime/probe.env")}"
  [[ -n "$persona" ]] ||
    die "no seeded persona found — run: devctl seed (or pass a did:plc:... explicitly)"

  token="$(python3 "$DEVENV_DIR/firebase/mint_token.py" "$persona")" || exit 1

  cat <<EOF
devctl: open this to sign in as the seeded persona ($persona):

  http://127.0.0.1:${FRONTEND_PORT}/#/auth/finish?token=${token}

The token is unsigned and only works against the Auth emulator. It expires in
an hour; re-run devctl login for a fresh one.
EOF
}

cmd_logs() {
  # Two modes on purpose. The default prints and exits, so `devctl logs api`
  # is a question you can ask and get an answer to. Following is opt-in with
  # -t, because a follow on an idle environment prints the backlog and then
  # sits there silently, which reads exactly like a hang.
  local follow=0
  local passthrough=()
  local have_tail=0
  local arg
  for arg in "$@"; do
    case "$arg" in
    -t | -f | --follow)
      follow=1
      ;;
    --tail | --tail=*)
      have_tail=1
      passthrough+=("$arg")
      ;;
    *)
      passthrough+=("$arg")
      ;;
    esac
  done
  # Only supply a default line count when the caller didn't pick one, so
  # `devctl logs --tail=500 api` works.
  [[ $have_tail -eq 1 ]] || passthrough=(--tail=100 ${passthrough[@]+"${passthrough[@]}"})
  if [[ $follow -eq 1 ]]; then
    compose logs -f ${passthrough[@]+"${passthrough[@]}"}
  else
    compose logs ${passthrough[@]+"${passthrough[@]}"}
  fi
}

cmd_status() {
  compose ps
  echo
  if [[ -s "$DEVENV_DIR/.runtime/es_key_ro.env" ]]; then
    local alias
    for alias in posts likes inferences; do
      printf "%-12s %s docs\n" "$alias" \
        "$(es_curl "/${alias}/_count" | sed -n 's/.*"count":\([0-9]*\).*/\1/p')"
    done
  fi
}

cmd_nuke() {
  compose down -v --remove-orphans
  rm -rf "$DEVENV_DIR/.runtime"
  rm -f "$GE_DEV_REPO_ROOT/frontend/firebase.devenv.json"
  echo "devctl: all containers, data volumes, and runtime state removed."
}

usage() {
  cat <<EOF
devctl — Green Earth local dev environment

Usage: devctl <command> [args]

  setup          check prerequisites, build/pull images, download models,
                 install inference-service's dependencies
  fetch-fixture  download the published fixture set (no account or auth needed)
  fetch-models   download the pinned trained models (no account or auth needed)
  up             start the stack (ES + Firestore emulator + inference + api)
                 --live es,inference,perspective  use deployed services
                 --live-env stage|prod            which deployment (default stage)
                 --with-jetstream                 also stream live likes
  tunnel [env]   port-forward a deployed Elasticsearch, for --live es
  seed           load fixtures: rebase timestamps, ingest posts, load likes
  feed [feed]    view a hydrated feed in the terminal (default: your-feed;
                 --user <did>, --limit, --pages, --json for raw skeleton)
  login [did]    print a sign-in URL for the frontend as the seeded persona
  status         container status + index doc counts
  logs [svc...]  print recent logs and exit (-t follows instead)
  down           stop containers (data volumes survive)
  nuke           stop and delete everything (volumes, minted keys, seed state)

Fixtures: fetch-fixture downloads a published set; fixtures/generate_sample.py
generates your own (two modes), fixtures/publish_fixture.sh publishes one.
Models: fetch-models downloads the pinned release; models/publish_models.sh
mirrors a new set out of the prod bucket (maintainers).
Live services need a key in devenv.local.env: GE_DEV_ES_API_KEY,
GE_DEV_INFERENCE_API_KEY, GE_PERSPECTIVE_API_KEY. Set GE_DEV_LIVE there to
make the choice stick without passing --live every time.
Other config overrides go in the same file (ports, ES heap, repo root).
EOF
}

# ---------------------------------------------------------------------------

cmd="${1:-}"
[[ -n "$cmd" ]] && shift || true
case "$cmd" in
setup) cmd_setup "$@" ;;
fetch-fixture) cmd_fetch_fixture "$@" ;;
fetch-models) cmd_fetch_models "$@" ;;
up) cmd_up "$@" ;;
tunnel) cmd_tunnel "$@" ;;
seed) cmd_seed "$@" ;;
feed) cmd_feed "$@" ;;
login) cmd_login "$@" ;;
status | ps) cmd_status "$@" ;;
logs) cmd_logs "$@" ;;
down)
  compose down
  rm -f "$GE_DEV_REPO_ROOT/frontend/firebase.devenv.json"
  ;;
nuke) cmd_nuke "$@" ;;
"" | help | -h | --help) usage ;;
*) die "unknown command: $cmd (try: devctl help)" ;;
esac
