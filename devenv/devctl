#!/usr/bin/env bash
# devctl — Green Earth local development environment (issue api#268).
#
# Orchestrates the docker-compose stack in this directory. The key sequencing
# it owns: es-init must complete (minting ES API keys into .runtime/) before
# the api starts, and seeding runs rebase -> megastream ingest -> likes.
#
# Layout assumption: this repo (internal-tools) is checked out next to its
# sibling repos (api, ingex, ...) under one parent directory, like the
# greenearth-social monorepo checkout. Override with GE_DEV_REPO_ROOT.
set -euo pipefail

DEVENV_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

die() {
  echo "devctl: $*" >&2
  exit 1
}

# Optional local overrides (ports, ES heap, ...). Gitignored.
if [[ -f "$DEVENV_DIR/devenv.local.env" ]]; then
  set -a
  # shellcheck source=/dev/null
  source "$DEVENV_DIR/devenv.local.env"
  set +a
fi

command -v python3 >/dev/null || {
  echo "devctl: python3 is required" >&2
  exit 1
}

# --- instances (issue api#283) -----------------------------------------------
# `--name <n>` runs a second, fully independent environment: its own compose
# project (so its own containers, network and volumes), its own runtime
# directory, and its own block of published ports. Two agents can then work on
# two branches at once without either noticing the other.
#
# The flag is global rather than per-command — every command has to act on the
# same instance — so it's stripped here, from anywhere in the argument list.
# The exception is `exec`, whose trailing arguments belong to the command being
# run inside the container and must reach it untouched.
INSTANCE="${GE_DEV_INSTANCE:-dev}"
_args=()
while [[ $# -gt 0 ]]; do
  case "$1" in
  --name)
    [[ -n "${2:-}" ]] || {
      echo "devctl: --name needs an instance name" >&2
      exit 1
    }
    INSTANCE="$2"
    shift 2
    ;;
  exec)
    _args+=("$@")
    break
    ;;
  *)
    _args+=("$1")
    shift
    ;;
  esac
done
set -- ${_args[@]+"${_args[@]}"}

# Compose project names accept lowercase alphanumerics, dashes and underscores;
# ours also becomes part of a runtime directory name and a config filename.
set_instance() {
  INSTANCE="$1"
  [[ "$INSTANCE" =~ ^[a-z0-9][a-z0-9_-]*$ ]] ||
    die "invalid instance name: '$INSTANCE' (lowercase letters, digits, - and _)"
  export GE_DEV_NAME="ge-$INSTANCE"
  if [[ "$INSTANCE" == "dev" ]]; then
    export GE_DEV_RUNTIME="./.runtime"
    export GE_DEV_FIREBASE_CONFIG="firebase.devenv.json"
  else
    export GE_DEV_RUNTIME="./.runtime.$INSTANCE"
    export GE_DEV_FIREBASE_CONFIG="firebase.devenv.$INSTANCE.json"
  fi
  # GE_DEV_RUNTIME is relative because compose resolves it against
  # --project-directory; the shell needs the absolute form.
  RUNTIME="$DEVENV_DIR/${GE_DEV_RUNTIME#./}"
}

# Each instance costs roughly this much resident memory, measured with
# `docker stats` on a seeded environment: Elasticsearch ~1.9G (1g heap plus JVM
# overhead), the Firebase emulators ~350M, inference ~250M, and ~200M across
# the api, frontend and the two small stand-ins. A seed transiently adds more.
INSTANCE_MEMORY_GB=3
# On top of the per-instance figure: a seed runs an extra Go build and the
# rebase alongside everything else, and the machine needs room that isn't
# ours. Without this the arithmetic said two instances fit in 7.7GB, on the
# very machine where that combination got an Elasticsearch OOM-killed.
MEMORY_HEADROOM_GB=2

# Starting an instance on a machine that can't hold its Elasticsearch doesn't
# fail here — it gets *another* instance's ES OOM-killed some minutes later,
# which reads as "the environment broke" with nothing pointing at the cause.
# Only clusters count: a sharing instance adds ~1GB, not a JVM, so the real
# danger is two or more Elasticsearch-bearing instances at once. Warn rather
# than refuse — the estimate is approximate, and a smaller heap makes it wrong
# in the safe direction.
#
# Runs after the share decision, so share_es reflects this instance.
check_memory_budget() {
  local total_gb running dir name bearers=0
  total_gb="$(docker info --format '{{.MemTotal}}' 2>/dev/null || echo 0)"
  total_gb=$((total_gb / 1024 / 1024 / 1024))
  [[ "$total_gb" -gt 0 ]] || return 0

  running="$(running_projects)"

  # Running instances that carry their own cluster (i.e. aren't sharers).
  for dir in "$DEVENV_DIR"/.runtime "$DEVENV_DIR"/.runtime.*; do
    [[ -d "$dir" ]] || continue
    name="$(runtime_instance "$dir")"
    [[ " $running " == *" ge-$name "* ]] || continue
    grep -q '^GE_DEV_SHARE_ES=1' "$dir/share.env" 2>/dev/null && continue
    bearers=$((bearers + 1))
  done
  # Plus this instance if it bears a cluster and isn't already counted above.
  if ! share_es && [[ " $running " != *" ge-$INSTANCE "* ]]; then
    bearers=$((bearers + 1))
  fi
  [[ "$bearers" -gt 1 ]] || return 0

  local needed=$((bearers * INSTANCE_MEMORY_GB + MEMORY_HEADROOM_GB))
  [[ "$needed" -gt "$total_gb" ]] || return 0
  cat >&2 <<EOF
devctl: WARNING — $bearers instances run their own Elasticsearch, needing roughly
        ${needed}GB, and Docker has ${total_gb}GB. The usual symptom is one of
        them being OOM-killed mid-run (exit 137), not a failure here. Give
        Docker more memory, set GE_DEV_ES_HEAP=512m in devenv.local.env, share
        a cluster (named instances do by default — drop --dedicated-es), or
        stop one: devctl ls
EOF
}

# Published ports for this instance. `allocate` claims a free block on first
# use and remembers it; `read` refuses to invent one, so a mistyped --name is
# an error rather than a second empty environment.
resolve_ports() {
  # Once per run: the values it exports are the same GE_DEV_PORT_* names it
  # reads as bases, so calling it twice for a named instance would add the
  # offset to an already-offset port.
  [[ -z "${GE_DEV_PORT_OFFSET:-}" ]] || return 0
  local assignments
  assignments="$(python3 "$DEVENV_DIR/ports.py" "$DEVENV_DIR" "$INSTANCE" "${1:-read}")" || exit 1
  set -a
  eval "$assignments"
  set +a
  API_PORT="$GE_DEV_PORT_API"
  ES_PORT="$GE_DEV_PORT_ES"
  FIRESTORE_PORT="$GE_DEV_PORT_FIRESTORE"
  AUTH_PORT="$GE_DEV_PORT_FIREBASE_AUTH"
  FUNCTIONS_PORT="$GE_DEV_PORT_FUNCTIONS"
  FIREBASE_UI_PORT="$GE_DEV_PORT_FIREBASE_UI"
  FRONTEND_PORT="$GE_DEV_PORT_FRONTEND"
}

# Only shown for named instances: on the default one it's noise, since those
# are the numbers in the README and in everybody's bookmarks.
instance_label() {
  [[ "$INSTANCE" == "dev" ]] || echo " [$INSTANCE]"
}

# Everything below — the live-mode state file, the minted keys, the compose
# project — is per instance, so this has to settle before any of it is read.
set_instance "$INSTANCE"

# --- repo root ---------------------------------------------------------------
# Which checkouts this instance bind-mounts. Defaults to the monorepo checkout
# holding this internal-tools; `up --repo-root <dir>` points an instance at a
# different working copy, so parallel instances can carry parallel changes
# (see docs/agents.md). Handled like the live/share choices: `up` decides —
# flag, else explicit GE_DEV_REPO_ROOT, else what's already recorded — and
# records the result in .runtime/, and every other command reads the record,
# so exec/test/nuke act on the code the containers actually mount and a later
# bare `up` recreates against it instead of quietly reverting to the default.
DEFAULT_REPO_ROOT="$(cd "$DEVENV_DIR/../.." && pwd)"
REPO_ROOT_STATE="$RUNTIME/repo_root.env"
REPO_ROOT_CONFIGURED="${GE_DEV_REPO_ROOT:-}"
if [[ -f "$REPO_ROOT_STATE" ]]; then
  set -a
  # shellcheck source=/dev/null
  source "$REPO_ROOT_STATE"
  set +a
fi
export GE_DEV_REPO_ROOT="${GE_DEV_REPO_ROOT:-$DEFAULT_REPO_ROOT}"

record_repo_root() {
  printf 'GE_DEV_REPO_ROOT=%s\n' "$GE_DEV_REPO_ROOT" >"$REPO_ROOT_STATE"
}

FIXTURE_REPO="${GE_DEV_FIXTURE_REPO:-greenearth-social/internal-tools}"
FIXTURE_ASSET="ge-dev-fixture.tar"
MODELS_ASSET="ge-dev-models.tar"
# Pinned, unlike the fixture, which tracks the newest release. Model artifacts
# and seeded post embeddings have to agree — the towers only make sense over
# embeddings produced by the matching post tower — so everyone runs the same
# models until someone deliberately moves this. The tag names the two training
# runs in the bundle (two-tower, ranker); models/publish_models.sh derives it
# from the artifacts and prints what to set here.
MODELS_TAG="${GE_DEV_MODELS_TAG:-models-1bf1ea3c-177899dd}"

compose() {
  docker compose -f "$DEVENV_DIR/docker-compose.yml" --project-directory "$DEVENV_DIR" "$@"
}

# --- helpers shared across commands ----------------------------------------

# The value of one KEY=value line in a runtime env file, or nothing. "Or
# nothing" includes the file not existing — that must read as empty, not as a
# failure `set -e` turns fatal mid-assignment.
env_file_value() {
  sed -n "s/^$2=//p" "$1" 2>/dev/null || true
}

# " --name <n>" when a hint needs the flag spelled out; empty on the default
# instance, whose commands work bare.
name_flag() {
  [[ "$INSTANCE" == "dev" ]] || echo " --name $INSTANCE"
}

service_running() {
  compose ps --status running "$1" 2>/dev/null | grep -q "$1"
}

# compose exec with a TTY when stdout is one (so pytest and rich colorize and
# ^C reaches the process) and -T when piped, where allocation would fail.
# PIPENV_VERBOSITY silences pipenv's "existing virtualenv" warning per call.
# The "${arr[@]+...}" guard keeps an empty array from tripping `set -u` on
# macOS's bash 3.2.
compose_exec() {
  local tty=()
  [[ -t 1 ]] || tty=(-T)
  compose exec ${tty[@]+"${tty[@]}"} -e PIPENV_VERBOSITY=-1 "$@"
}

# The compose projects docker reports as running ("ge-dev ge-alpha ...").
running_projects() {
  docker compose ls --format json 2>/dev/null |
    python3 -c "
import json, sys
try:
    print(' '.join(p['Name'] for p in json.load(sys.stdin)))
except Exception:
    pass" 2>/dev/null || true
}

# Instance name from a runtime directory path (.runtime -> dev). The inverse
# lives in ports.py as instance_name; this saves a python startup per call.
runtime_instance() {
  local base="${1##*/}"
  if [[ "$base" == ".runtime" ]]; then echo "dev"; else echo "${base#.runtime.}"; fi
}

# "Next: ..." guidance, suppressed inside bootstrap, where the next step is
# about to run anyway and a printed suggestion mid-stream reads as a request.
hint() {
  [[ -n "${IN_BOOTSTRAP:-}" ]] || echo "$*"
}

# ---------------------------------------------------------------------------

check_docker() {
  command -v docker >/dev/null || die "docker is required (https://docs.docker.com/get-docker/)"
  docker info >/dev/null 2>&1 || die "docker daemon isn't running"
  docker compose version >/dev/null 2>&1 || die "docker compose v2 is required"
}

check_repos() {
  local missing=0
  local repo
  for repo in api ingex frontend inference-service; do
    if [[ ! -e "$GE_DEV_REPO_ROOT/$repo/.git" ]]; then
      echo "devctl: required repo missing: $GE_DEV_REPO_ROOT/$repo" >&2
      echo "        clone it: git clone git@github.com:greenearth-social/$repo.git \"$GE_DEV_REPO_ROOT/$repo\"" >&2
      missing=1
    fi
  done
  [[ $missing -eq 0 ]] || die "missing required repos (or set GE_DEV_REPO_ROOT to the directory that contains them)"
  # Only needed to retrain or republish models, not to run the environment.
  [[ -e "$GE_DEV_REPO_ROOT/engagement-prediction/.git" ]] ||
    echo "devctl: note: optional repo not checked out: $GE_DEV_REPO_ROOT/engagement-prediction" >&2
}

# The Go module and build caches are declared external so that they survive
# one instance's `nuke` and are shared by all of them; compose won't create an
# external volume, so we do. Also used directly by `devctl test ingex`, whose
# ephemeral container isn't a compose service.
GO_IMAGE="golang:1.25"

ensure_go_caches() {
  local volume
  for volume in ge-dev-gomod ge-dev-gocache; do
    docker volume inspect "$volume" >/dev/null 2>&1 ||
      docker volume create "$volume" >/dev/null
  done
}

ensure_runtime() {
  ensure_go_caches
  mkdir -p "$RUNTIME/seed" "$DEVENV_DIR/models/data"
  # compose env_file entries must exist before any `compose` invocation.
  touch "$RUNTIME/es_key_ro.env" \
    "$RUNTIME/es_key_rw.env" \
    "$RUNTIME/probe.env" \
    "$DEVENV_DIR/models/data/models.env"
}

# --- live services ----------------------------------------------------------
# Everything runs locally by default. `--live <svc>[,<svc>]` (or GE_DEV_LIVE in
# devenv.local.env) points individual dependencies at deployed ones instead,
# for the cases where the local stand-in can't reproduce what you're chasing.
#
#   devctl up --live inference,perspective
#   devctl up --live es --live-env prod
#
# `up` is the only command that decides: it reads the flag, falling back to
# devenv.local.env, and records the result in .runtime/. Every other command
# reads that record, so `seed` and `status` act on the environment that is
# actually running. Deciding this way means a bare `devctl up` always returns
# to all-local, instead of quietly inheriting a live service from hours ago.

LIVE_STATE="$RUNTIME/live.env"
LIVE_CONFIGURED="${GE_DEV_LIVE:-}"
LIVE_ENV_CONFIGURED="${GE_DEV_LIVE_ENV:-stage}"
if [[ -f "$LIVE_STATE" ]]; then
  set -a
  # shellcheck source=/dev/null
  source "$LIVE_STATE"
  set +a
fi
GE_DEV_LIVE="${GE_DEV_LIVE:-}"
GE_DEV_LIVE_ENV="${GE_DEV_LIVE_ENV:-stage}"

# --- shared Elasticsearch (issue api#283) ------------------------------------
# Elasticsearch is ~1.9GB of an instance's ~3GB, so by default a *named*
# instance doesn't run one — it reads the default instance's cluster. A second
# environment then costs about a gigabyte instead of three, which is the
# difference between "two fit" and "the first one's ES gets OOM-killed".
#
# The default instance ("dev") always owns a cluster. A named instance shares
# it unless `--dedicated-es` asks for its own — the one case that needs it is
# working on seeding or the index setup itself, since a sharer is read-only.
#
# Read-only is enforced the way live mode is: seed, nuke-of-data and live
# ingest refuse from a sharing instance, naming the owner. The api only reads,
# so it gets the owner's read-only key and reaches the cluster the same way
# `--live es` reaches a deployed one — through the host, at the owner's port.
ES_OWNER="dev"
ES_OWNER_RUNTIME="$DEVENV_DIR/.runtime"
SHARE_STATE="$RUNTIME/share.env"
if [[ -f "$SHARE_STATE" ]]; then
  set -a
  # shellcheck source=/dev/null
  source "$SHARE_STATE"
  set +a
fi

# True when this instance reads the owner's cluster instead of its own. The
# owner never shares, whatever a stray GE_DEV_SHARE_ES in the environment says.
share_es() { [[ "$INSTANCE" != "$ES_OWNER" && "${GE_DEV_SHARE_ES:-}" == "1" ]]; }

# The owner's published ES port. Every instance's ES_PORT is base+offset, so
# subtracting this instance's own offset lands on the base — the owner's port.
owner_es_port() { echo "$((ES_PORT - GE_DEV_PORT_OFFSET))"; }

owner_ro_key() {
  env_file_value "$ES_OWNER_RUNTIME/es_key_ro.env" GE_ELASTICSEARCH_API_KEY
}

record_share_choice() {
  printf 'GE_DEV_SHARE_ES=%s\n' "${GE_DEV_SHARE_ES:-}" >"$SHARE_STATE"
}

# Point the api at the owner's cluster and serve the owner's persona (since it's
# the owner's data). Reachable via host.docker.internal, exactly as a deployed
# cluster is under `--live es`.
resolve_shared_es() {
  share_es || return 0
  local key
  key="$(owner_ro_key)"
  [[ -n "$key" ]] || die "shared Elasticsearch needs the '$ES_OWNER' instance up first:
        devctl up
    Or give this instance its own cluster:
        devctl up --name $INSTANCE --dedicated-es"
  export GE_DEV_ES_API_KEY="$key"
  export GE_DEV_ES_URL="http://host.docker.internal:$(owner_es_port)"
  cp "$ES_OWNER_RUNTIME/probe.env" "$RUNTIME/probe.env" 2>/dev/null || true
}

# Reached from the host before the api depends on it, so an owner that isn't
# running is a clear message here rather than a feed that 500s later.
preflight_shared_es() {
  share_es || return 0
  local code
  code="$(curl -s -o /dev/null -w '%{http_code}' --max-time 10 \
    -H "Authorization: ApiKey ${GE_DEV_ES_API_KEY}" \
    "http://127.0.0.1:$(owner_es_port)/_cluster/health" 2>/dev/null || true)"
  case "$code" in
  200) echo "devctl: sharing the '$ES_OWNER' instance's Elasticsearch (127.0.0.1:$(owner_es_port), read-only)" ;;
  000) die "the '$ES_OWNER' instance's Elasticsearch isn't reachable on port $(owner_es_port).
        Start it:              devctl up
        Or run standalone:     devctl up --name $INSTANCE --dedicated-es" ;;
  *) die "shared Elasticsearch returned HTTP $code from the '$ES_OWNER' instance" ;;
  esac
}

# Named instances that read this instance's cluster — checked before nuking or
# stopping the owner, whose volumes hold data they're serving.
sharers_of_owner() {
  local dir name out=""
  for dir in "$DEVENV_DIR"/.runtime.*; do
    [[ -d "$dir" ]] || continue
    grep -q '^GE_DEV_SHARE_ES=1' "$dir/share.env" 2>/dev/null || continue
    name="${dir##*/.runtime.}"
    out+="$name "
  done
  echo "${out% }"
}

# --- seed staleness ---------------------------------------------------------
# The rebase leaves the fixture window ending an hour before seed time, and
# the api's popularity generator only looks back 24h (RECENCY_WINDOW) — so
# from ~23 hours after a seed, recency-anchored feeds (popularity, your-feed)
# come back thin or empty with nothing visibly wrong. That's the single most
# misleading failure this environment has, so it's warned about wherever the
# symptom would otherwise surface.
STALE_SEED_HOURS=23

# Where this instance's data was seeded: a sharer serves the owner's data, so
# its staleness is the owner's.
seed_runtime() {
  if share_es; then echo "$ES_OWNER_RUNTIME"; else echo "$RUNTIME"; fi
}

# Hours since the last seed; nothing if never seeded (or seeded before this
# was recorded).
seed_age_hours() {
  local seeded
  seeded="$(env_file_value "$(seed_runtime)/seed.env" GE_DEV_SEEDED_AT)"
  [[ -n "$seeded" ]] || return 0
  echo $((($(date +%s) - seeded) / 3600))
}

warn_stale_seed() {
  local age
  age="$(seed_age_hours)"
  [[ -n "$age" && "$age" -ge "$STALE_SEED_HOURS" ]] || return 0
  local target="devctl seed"
  if share_es; then
    target="devctl seed   (on the '$ES_OWNER' instance, which owns the data)"
  fi
  cat >&2 <<EOF
devctl: the data was seeded ${age}h ago and has drifted out of the api's 24h
        recency window — recency-anchored feeds come back thin or empty from
        here. Re-seed: $target
EOF
}

LIVE_SERVICES="es inference perspective"

live_has() {
  case ",${GE_DEV_LIVE}," in
  *",$1,"*) return 0 ;;
  *) return 1 ;;
  esac
}

# Where each live service actually is, and which variable holds its key. Kept
# here so nobody has to remember a Cloud Run hostname to use one.
live_url() {
  case "$1:$GE_DEV_LIVE_ENV" in
  inference:stage) echo "https://inference-stage.greenearth.social" ;;
  inference:prod) echo "https://inference.greenearth.social" ;;
  perspective:*) echo "https://commentanalyzer.googleapis.com" ;;
  # Reached through the tunnel `devctl tunnel` opens: the cluster's ES sits
  # behind an internal load balancer, so there's no address a container could
  # dial directly. host.docker.internal is the host running kubectl.
  es:*) echo "https://host.docker.internal:${GE_DEV_ES_TUNNEL_PORT:-9200}" ;;
  esac
}

live_key_var() {
  case "$1" in
  inference) echo GE_DEV_INFERENCE_API_KEY ;;
  perspective) echo GE_PERSPECTIVE_API_KEY ;;
  es) echo GE_DEV_ES_API_KEY ;;
  esac
}

# Turns GE_DEV_LIVE into the GE_DEV_*_URL variables docker-compose.yml reads,
# after checking that each service named there is real and has a key. Failing
# here beats failing as a 401 inside a container ten seconds later.
resolve_live() {
  # Environment first: a typo'd --live-env would otherwise be reported as
  # whichever key happened to be missing, which reads as an unrelated problem.
  case "$GE_DEV_LIVE_ENV" in
  stage | prod) ;;
  *) die "--live-env must be stage or prod (got: $GE_DEV_LIVE_ENV)" ;;
  esac

  local svc
  for svc in ${GE_DEV_LIVE//,/ }; do
    [[ " $LIVE_SERVICES " == *" $svc "* ]] ||
      die "unknown live service: $svc (choose from: $LIVE_SERVICES)"
    local key_var
    key_var="$(live_key_var "$svc")"
    [[ -n "${!key_var:-}" ]] ||
      die "--live $svc needs $key_var — set it in devenv.local.env"
  done

  # GE_DEV_INFERENCE_URL doubles as the escape hatch for an inference service
  # that isn't one of ours — one you're running by hand, say. Setting it
  # directly skips the lookup above but still routes the api away from local.
  if live_has inference; then
    export GE_DEV_INFERENCE_URL="${GE_DEV_INFERENCE_URL:-$(live_url inference)}"
  fi
  live_has perspective && export GE_DEV_PERSPECTIVE_HOST="$(live_url perspective)"
  live_has es && export GE_DEV_ES_URL="$(live_url es)"

  if [[ "$GE_DEV_LIVE_ENV" == "prod" && -n "$GE_DEV_LIVE" ]]; then
    echo "devctl: WARNING — using PROD services: $GE_DEV_LIVE" >&2
  fi
  return 0
}

record_live_choice() {
  cat >"$LIVE_STATE" <<EOF
GE_DEV_LIVE=$GE_DEV_LIVE
GE_DEV_LIVE_ENV=$GE_DEV_LIVE_ENV
EOF
}

# Reach each live service once, from the host, before anything depends on it.
# A bad key or a closed tunnel otherwise shows up as feeds that 500 with the
# reason buried in a container log.
#
# host.docker.internal is how a *container* names the host, and it doesn't
# resolve on the host itself — so probing it verbatim would report every tunnel
# as closed. Since that name only ever appears in the tunnel URL, and a tunnel
# is a host-local listener, 127.0.0.1 is the same endpoint seen from here.
probe_url() {
  echo "${1//host.docker.internal/127.0.0.1}"
}

preflight_live() {
  local code
  if live_has inference; then
    code="$(curl -sk -o /dev/null -w '%{http_code}' --max-time 15 \
      -H "X-API-Key: ${GE_DEV_INFERENCE_API_KEY}" \
      "$(probe_url "$GE_DEV_INFERENCE_URL")/ready" 2>/dev/null || true)"
    case "$code" in
    200) echo "devctl: live inference OK ($GE_DEV_INFERENCE_URL)" ;;
    401 | 403) die "live inference rejected GE_DEV_INFERENCE_API_KEY (HTTP $code)" ;;
    000) die "live inference unreachable at $GE_DEV_INFERENCE_URL" ;;
    *) die "live inference returned HTTP $code from $GE_DEV_INFERENCE_URL/ready" ;;
    esac
  fi
  if live_has es; then
    code="$(curl -sk -o /dev/null -w '%{http_code}' --max-time 15 \
      -H "Authorization: ApiKey ${GE_DEV_ES_API_KEY}" \
      "$(probe_url "$GE_DEV_ES_URL")/_cluster/health" 2>/dev/null || true)"
    case "$code" in
    200) echo "devctl: live Elasticsearch OK ($GE_DEV_ES_URL)" ;;
    401 | 403) die "live Elasticsearch rejected GE_DEV_ES_API_KEY (HTTP $code)" ;;
    000) die "live Elasticsearch unreachable at $GE_DEV_ES_URL — is the tunnel open?
        devctl tunnel $GE_DEV_LIVE_ENV" ;;
    *) die "live Elasticsearch returned HTTP $code" ;;
    esac
    check_es_key_readonly
  fi
  # Perspective isn't probed: every call costs quota, and a bad key surfaces
  # immediately as a failed feed rather than something subtle.
}

# `--live es` points a *development* environment at a deployed cluster, and
# everything in this environment that writes to Elasticsearch — the seed, both
# ingest services — addresses the local one by name, so nothing here is
# supposed to write there. Enforce that at the key: prod publishes a read-only
# API key precisely for this (elasticsearch-api-key-readonly), and pasting the
# read-write one instead is an easy mistake with no natural symptom, because
# reading works identically either way.
#
# _has_privileges answers for whichever key authenticated the request, so this
# asks the cluster rather than trusting the key's name.
check_es_key_readonly() {
  [[ -z "${GE_DEV_ALLOW_ES_WRITE_KEY:-}" ]] || {
    echo "devctl: WARNING — live ES write check skipped (GE_DEV_ALLOW_ES_WRITE_KEY)" >&2
    return 0
  }
  local body
  body="$(curl -sk --max-time 15 -X POST \
    -H "Authorization: ApiKey ${GE_DEV_ES_API_KEY}" \
    -H 'Content-Type: application/json' \
    -d '{"index":[{"names":["*"],"privileges":["write","index","delete","create_index","delete_index","manage"]}]}' \
    "$(probe_url "$GE_DEV_ES_URL")/_security/user/_has_privileges" 2>/dev/null || true)"

  local granted
  granted="$(python3 - "$body" <<'PY' || echo UNKNOWN
import json, sys
try:
    resp = json.loads(sys.argv[1])
    per_index = resp["index"]
except (json.JSONDecodeError, KeyError, TypeError):
    print("UNKNOWN")
else:
    print(",".join(sorted(
        {name for privs in per_index.values() for name, ok in privs.items() if ok}
    )))
PY
  )"

  case "$granted" in
  "") echo "devctl: live Elasticsearch key is read-only" ;;
  UNKNOWN)
    die "couldn't verify that GE_DEV_ES_API_KEY is read-only — the cluster's
        answer to _has_privileges wasn't readable. Re-run with
        GE_DEV_ALLOW_ES_WRITE_KEY=1 if you're sure." ;;
  *)
    die "GE_DEV_ES_API_KEY can write to live Elasticsearch (grants: $granted).
        Use the read-only key — in prod that's the secret
        elasticsearch-api-key-readonly, the same one the deployed api reads
        with. Nothing in this environment writes to a live cluster, so a
        write-capable key here only adds risk." ;;
  esac
}

# The api reads its ES endpoint from the compose `environment` block rather
# than an env_file, so that it can be pointed at a deployed cluster (an
# `environment` entry always wins over env_file, so the file can't be the
# fallback). That makes supplying the local key devctl's job.
export_api_es_env() {
  if [[ -z "${GE_DEV_ES_API_KEY:-}" ]]; then
    GE_DEV_ES_API_KEY="$(env_file_value "$RUNTIME/es_key_ro.env" GE_ELASTICSEARCH_API_KEY)"
    [[ -n "$GE_DEV_ES_API_KEY" ]] ||
      die "no Elasticsearch key in $GE_DEV_RUNTIME/es_key_ro.env — run: devctl up$(name_flag)"
  fi
  export GE_DEV_ES_API_KEY
}

have_models() {
  [[ -f "$DEVENV_DIR/models/data/manifest.json" ]]
}

models_tag() {
  python3 -c "
import json
print(json.load(open('$DEVENV_DIR/models/data/manifest.json'))['tag'])"
}

models_hint() {
  cat >&2 <<EOF

No model artifacts found in devenv/models/data/. Get them:

  devctl fetch-models

That downloads the pinned release ($MODELS_TAG, ~33MB) — no account or
credentials needed. \`devctl setup\` does it for you.
EOF
}

# Nothing to compare until both halves are present; models/check_compat.py
# explains why this matters.
check_model_fixture_compat() {
  have_models && have_fixtures || return 0
  python3 "$DEVENV_DIR/models/check_compat.py" \
    "$DEVENV_DIR/models/data/manifest.json" \
    "$DEVENV_DIR/fixtures/data/manifest.json" || exit 1
}

es_curl() {
  local path="$1"
  shift
  local key port
  if share_es; then
    # A sharing instance has no cluster of its own; read the owner's.
    key="$(owner_ro_key)"
    port="$(owner_es_port)"
    [[ -n "$key" ]] || die "shared Elasticsearch not available — the '$ES_OWNER' instance owns it: devctl up"
  else
    key="$(env_file_value "$RUNTIME/es_key_ro.env" GE_ELASTICSEARCH_API_KEY)"
    port="$ES_PORT"
    [[ -n "$key" ]] || die "no ES key yet — run: devctl up$(name_flag)"
  fi
  curl -s -H "Authorization: ApiKey $key" "http://127.0.0.1:${port}${path}" "$@"
}

have_fixtures() {
  [[ -f "$DEVENV_DIR/fixtures/data/manifest.json" ]]
}

# Download a release asset and replace `dest` with its contents. Deliberately
# curl against the public releases API rather than the gh CLI: both these repos
# are public, so a fresh clone can fetch what it needs with no GitHub account,
# no auth, and no extra tooling installed.
fetch_release_asset() {
  local tag="$1" asset="$2" dest="$3" size="$4"
  command -v curl >/dev/null || die "curl is required to download $asset"

  local workdir
  workdir="$(mktemp -d)"
  # shellcheck disable=SC2064  # expand workdir now, not at trap time
  trap "rm -rf '$workdir'" RETURN

  echo "devctl: downloading $tag ($size)..."
  curl -fL --progress-bar \
    "https://github.com/$FIXTURE_REPO/releases/download/$tag/$asset" \
    -o "$workdir/$asset" ||
    die "download failed — check network access to github.com, and that $tag exists in $FIXTURE_REPO"

  # Extract into a scratch directory first so a torn archive can't leave the
  # destination holding half of one release and half of another.
  mkdir -p "$workdir/x"
  tar -xf "$workdir/$asset" -C "$workdir/x" || die "$tag: archive is unreadable"
  rm -rf "$dest"
  mkdir -p "$(dirname "$dest")"
  mv "$workdir/x" "$dest"
}

fixtures_hint() {
  cat >&2 <<EOF

No fixture set found in devenv/fixtures/data/. Get one:

  # Download the published sample (what you usually want):
  devctl fetch-fixture

  # Or generate your own from real data (needs read-only prod ES,
  # port-forwarded — see README):
  python3 $DEVENV_DIR/fixtures/generate_sample.py --source prod-es

  # Or without any credentials (uses ingex's checked-in sample files
  # and synthesizes the like graph):
  python3 $DEVENV_DIR/fixtures/generate_sample.py --source megastream-files

Then run: devctl seed
EOF
}

cmd_fetch_fixture() {
  command -v curl >/dev/null || die "curl is required to download fixtures"
  command -v python3 >/dev/null || die "python3 is required to download fixtures"

  # Newest fixture release, unlike the models, which are pinned — a fixture is
  # a sample of Bluesky rather than something the rest of the stack has to
  # agree with.
  local tag
  tag="$(curl -fsSL "https://api.github.com/repos/$FIXTURE_REPO/releases?per_page=50" 2>/dev/null |
    python3 -c "
import json, sys
try:
    releases = json.load(sys.stdin)
except json.JSONDecodeError:
    sys.exit(0)
tags = [r['tag_name'] for r in releases
        if isinstance(r, dict) and r.get('tag_name', '').startswith('fixture-')]
print(tags[0] if tags else '')
" 2>/dev/null || true)"
  if [[ -z "$tag" ]]; then
    die "no fixture release found in $FIXTURE_REPO (or GitHub is unreachable / rate-limiting).
Generate a set locally instead — see: devctl help"
  fi

  # Replace rather than merge: mixing chunks from different samples would give
  # the seed an inconsistent post/like graph.
  fetch_release_asset "$tag" "$FIXTURE_ASSET" "$DEVENV_DIR/fixtures/data" "~170MB"

  python3 - "$DEVENV_DIR/fixtures/data/manifest.json" <<'PY'
import json, sys, pathlib
m = json.loads(pathlib.Path(sys.argv[1]).read_text())
c = m["counts"]
print(f"devctl: fetched {c['posts']:,} posts / {c['likes']:,} likes "
      f"(window ends {m['window_end']}, source {m['source']})")
PY
  hint "Next: devctl up && devctl seed"
}

cmd_fetch_models() {
  # Same public-release channel as the fixture, and for the same reason: a
  # fresh clone gets working trained models with no Google account, no GCS
  # credentials and no ClearML.
  # Replace rather than merge: the serving manifests name specific weight
  # files, and a half-updated directory would load one release's towers
  # against another's author index map.
  fetch_release_asset "$MODELS_TAG" "$MODELS_ASSET" "$DEVENV_DIR/models/data" "~33MB"

  python3 - "$DEVENV_DIR/models/data/manifest.json" <<'PY'
import json, sys, pathlib
m = json.loads(pathlib.Path(sys.argv[1]).read_text())
print(f"devctl: fetched models {m['tag']} — {m['content_embedding_model']} "
      f"({m['content_embedding_dims']}d) in, {m['output_embedding_dim']}d out")
PY
  check_model_fixture_compat
  hint "Next: devctl up && devctl seed"
}

# ---------------------------------------------------------------------------

cmd_setup() {
  check_docker
  check_repos
  ensure_runtime
  echo "devctl: pulling and building images (first run takes a few minutes)..."
  compose --profile tools build es-init api inference firebase frontend
  compose --profile tools pull elasticsearch perspective-stub dev-auth seed-rebase seed-megastream --ignore-buildable

  have_models || cmd_fetch_models

  # Install inference-service's dependencies now rather than on first `up`.
  # torch is a few hundred MB; doing it here, where a wait is expected, keeps
  # `up` from looking hung the first time. It also keeps `up` runnable
  # offline, which is true of everything else here once setup has run.
  echo "devctl: preparing inference-service dependencies (one time, ~1 min)..."
  compose run --rm --no-deps inference bash /inference/start.sh --install-only ||
    die "failed to install inference-service dependencies"

  echo "devctl: setup complete."
  [[ -n "${IN_BOOTSTRAP:-}" ]] || have_fixtures || fixtures_hint
  hint "Next: devctl up && devctl seed"
}

cmd_bootstrap() {
  # Fresh clone to working, seeded environment in one command (issue api#284):
  # setup, fetch the fixture, start the stack, seed it. Each step skips work
  # that's already done, so an interrupted bootstrap resumes where it left off
  # rather than starting over. Extra flags pass through to `up`.
  IN_BOOTSTRAP=1
  # `up` parses and records --repo-root, but setup runs first and looks at the
  # same checkouts (check_repos, the inference dependency install), so the
  # flag's value has to apply before it — cmd_up validates and records it.
  local _prev="" _a
  for _a in "$@"; do
    [[ "$_prev" != "--repo-root" ]] || export GE_DEV_REPO_ROOT="$_a"
    _prev="$_a"
  done
  cmd_setup
  have_fixtures || cmd_fetch_fixture
  cmd_up "$@"
  if share_es; then
    echo "devctl: bootstrap complete$(instance_label) — serving the '$ES_OWNER' instance's data."
  else
    local posts
    posts="$(es_curl /posts/_count | sed -n 's/.*"count":\([0-9]*\).*/\1/p')"
    if [[ -z "$posts" || "$posts" == "0" ]]; then
      cmd_seed
    else
      echo "devctl: already seeded ($posts posts) — a fresh load is: devctl seed"
    fi
    echo "devctl: bootstrap complete$(instance_label)."
  fi
  echo "Try it:  devctl feed$(name_flag)     (a ranked feed, in the terminal)"
  echo "         open http://127.0.0.1:${FRONTEND_PORT}"
}

cmd_up() {
  local jetstream=0 megastream=0 dedicated_es=0 repo_root=""
  # Start from what's configured, not from what the last `up` recorded, so this
  # command fully determines the result.
  GE_DEV_LIVE="$LIVE_CONFIGURED"
  GE_DEV_LIVE_ENV="$LIVE_ENV_CONFIGURED"
  while [[ $# -gt 0 ]]; do
    case "$1" in
    --with-jetstream)
      jetstream=1
      shift
      ;;
    # Give this named instance its own Elasticsearch instead of reading the
    # owner's. The reason to want it is a change to seeding or the index setup,
    # which a sharer (read-only) can't exercise. Costs ~1.9GB more.
    --dedicated-es)
      dedicated_es=1
      shift
      ;;
    --with-megastream)
      megastream=1
      shift
      ;;
    # Mount a different set of checkouts (a second working copy, a set of git
    # worktrees) into this instance, so parallel instances can work on
    # parallel copies of the code. Recorded per instance: later commands and
    # later `up`s keep it until another --repo-root (or nuke) changes it.
    --repo-root)
      [[ -n "${2:-}" ]] || die "--repo-root needs a directory"
      repo_root="$2"
      shift 2
      ;;
    # Posts and likes are two halves of the same firehose; one without the
    # other is rarely what anyone wants.
    --with-ingest)
      jetstream=1
      megastream=1
      shift
      ;;
    --live)
      GE_DEV_LIVE="$2"
      shift 2
      ;;
    --live-env)
      GE_DEV_LIVE_ENV="$2"
      shift 2
      ;;
    # Off by default (issue api#283): a rebuild triggered by an editor autosave
    # is wasted work at best, and at worst it restarts the api underneath an
    # agent that's mid-request. Agents rebuild deliberately with
    # `devctl restart <service>`; people who want a reload loop ask for one.
    --watch)
      export GE_DEV_API_RELOAD=1 GE_DEV_INFERENCE_RELOAD=1
      shift
      ;;
    *) die "unknown argument to up: $1 (try: devctl help)" ;;
    esac
  done

  # `up` decides the repo root: the flag, else an explicit GE_DEV_REPO_ROOT
  # from the caller, else whatever this instance already mounts (the record,
  # applied above). Absolute, because compose resolves bind mounts against
  # --project-directory, not against the shell's cwd.
  local want_root="$GE_DEV_REPO_ROOT"
  [[ -z "$REPO_ROOT_CONFIGURED" ]] || want_root="$REPO_ROOT_CONFIGURED"
  [[ -z "$repo_root" ]] || want_root="$repo_root"
  GE_DEV_REPO_ROOT="$(cd "$want_root" 2>/dev/null && pwd)" ||
    die "repo root doesn't exist: $want_root"
  export GE_DEV_REPO_ROOT

  check_docker
  check_repos
  resolve_ports allocate
  ensure_runtime
  record_repo_root
  resolve_live
  record_live_choice

  # A named instance shares the owner's cluster by default; --dedicated-es or
  # its own --live es opt out. `--live es` points somewhere else entirely, so
  # there's nothing to share. Decided here and recorded, so seed/status/es on
  # this instance all agree about where its data lives.
  if [[ "$INSTANCE" != "$ES_OWNER" && $dedicated_es -eq 0 ]] && ! live_has es; then
    export GE_DEV_SHARE_ES=1
  else
    export GE_DEV_SHARE_ES=""
  fi
  record_share_choice
  check_memory_budget
  resolve_shared_es

  if share_es && { [[ $megastream -eq 1 || $jetstream -eq 1 ]]; }; then
    die "live ingestion writes to Elasticsearch, but this instance shares the
        '$ES_OWNER' instance's cluster (read-only here). Run ingest on the owner,
        or give this one its own: devctl up --name $INSTANCE --dedicated-es"
  fi

  # One list, built from what's staying local. A live service's container isn't
  # just skipped but stopped: it's still a defined service, so --remove-orphans
  # leaves it running, and it would go on answering nothing. A sharing instance
  # runs no Elasticsearch at all — it reads the owner's.
  local local_services=(firebase dev-auth)
  share_es || local_services+=(elasticsearch)
  local svc
  for svc in inference perspective-stub; do
    local name="${svc%-stub}"
    if live_has "$name"; then
      compose stop "$svc" >/dev/null 2>&1 || true
    else
      local_services+=("$svc")
    fi
  done

  if ! live_has inference; then
    have_models || { models_hint; exit 1; }
    check_model_fixture_compat
  fi
  preflight_live

  # Checked before anything starts: without these the container just fails its
  # config validation and restarts, which reads as a broken environment rather
  # than a missing setting. Jetstream needs no equivalent — it's a public
  # firehose.
  if [[ $megastream -eq 1 ]]; then
    [[ -n "${GE_AWS_S3_ACCESS_KEY:-}" && -n "${GE_AWS_S3_SECRET_KEY:-}" ]] ||
      die "--with-megastream needs GE_AWS_S3_ACCESS_KEY and GE_AWS_S3_SECRET_KEY
        in devenv.local.env — the post archives are a private bucket, unlike
        the public Jetstream firehose."
  fi

  # --remove-orphans clears containers for services this file no longer
  # defines — e.g. the standalone `firestore` emulator that the Firebase
  # suite replaced, which would otherwise linger holding its old port.
  # --wait because the api no longer depends_on the swappable ones, so this is
  # what guarantees they're serving before it starts.
  compose up -d --remove-orphans --wait "${local_services[@]}"
  # A sharing instance runs no cluster of its own, so there's nothing to
  # initialize and the api's key is the owner's (already exported). Its api
  # also can't `depends_on: elasticsearch` — that service isn't started here —
  # so start it without deps; the things it truly needs (firebase) are up.
  local api_up=(compose up -d)
  if share_es; then
    preflight_shared_es
    api_up+=(--no-deps)
  else
    echo "devctl: initializing Elasticsearch (templates, indexes, API keys)..."
    compose run --rm es-init
    export_api_es_env
  fi
  "${api_up[@]}" api frontend
  cat <<EOF
devctl: environment is up$(instance_label).
  frontend      http://127.0.0.1:${FRONTEND_PORT}    (first start installs deps; watch: devctl logs -t frontend)
  api           http://127.0.0.1:${API_PORT}    (first start installs deps; watch: devctl logs -t api)
EOF
  [[ "$GE_DEV_REPO_ROOT" == "$DEFAULT_REPO_ROOT" ]] ||
    echo "  code          mounted from $GE_DEV_REPO_ROOT"
  if share_es; then
    echo "  elasticsearch shared from '$ES_OWNER' (127.0.0.1:$(owner_es_port))    read-only here"
  else
    echo "  elasticsearch http://127.0.0.1:${ES_PORT}    (user elastic / ${GE_DEV_ES_PASSWORD:-ge-dev-elastic})"
  fi
  cat <<EOF
  firestore     127.0.0.1:${FIRESTORE_PORT}    (emulator, from the frontend checkout)
  firebase auth 127.0.0.1:${AUTH_PORT}
  functions     127.0.0.1:${FUNCTIONS_PORT}
  emulator UI   http://127.0.0.1:${FIREBASE_UI_PORT}    (browse Firestore data, auth users, function logs)
EOF
  if live_has inference; then
    echo "  inference     LIVE $GE_DEV_INFERENCE_URL"
  else
    echo "  inference     $(models_tag)    (watch: devctl logs -t inference)"
  fi
  live_has es && echo "  ** the api is reading LIVE Elasticsearch: $GE_DEV_ES_URL"
  live_has perspective && echo "  ** the api is calling the LIVE Perspective API"
  if [[ $megastream -eq 1 ]]; then
    compose --profile megastream up -d megastream-ingest
    echo "  megastream    streaming live posts from the archives (needs internet)"
  fi
  if [[ $jetstream -eq 1 ]]; then
    compose --profile jetstream up -d jetstream-ingest
    echo "  jetstream     streaming live likes from the public firehose (needs internet)"
  fi
  # Likes arriving for posts the index will never hold is a confusing way to
  # run, and the reverse leaves the like graph frozen.
  if [[ $jetstream -ne $megastream ]]; then
    echo "  ** only half of live ingestion is on; --with-ingest runs both" >&2
  fi
  if [[ "$INSTANCE" != "dev" ]]; then
    echo "  ** instance '$INSTANCE' — every other devctl command needs --name $INSTANCE"
  fi
  # The posts alias doesn't exist until the first seed (the ingest binary
  # creates it, as in prod) — treat a missing alias like an empty index. A
  # sharer can't seed, so an empty owner is the owner's problem, not a prompt
  # to run something here.
  local post_count
  post_count="$(es_curl /posts/_count | sed -n 's/.*"count":\([0-9]*\).*/\1/p')"
  if [[ -z "$post_count" || "$post_count" == "0" ]]; then
    if share_es; then
      echo "The shared '$ES_OWNER' cluster has no posts yet — seed it: devctl seed"
    elif have_fixtures; then
      echo "Elasticsearch is empty — run: devctl seed"
    else
      fixtures_hint
    fi
  fi
}

cmd_seed() {
  check_docker
  ensure_runtime
  # A sharing instance has no cluster of its own and only a read-only key to
  # the owner's, so there is nothing here it may seed. Point at the owner
  # rather than fail obscurely on a missing key.
  if share_es; then
    die "this instance shares the '$ES_OWNER' instance's Elasticsearch, which is read-only here.
        Seed the owner:                 devctl seed$([[ "$ES_OWNER" == "dev" ]] || echo " --name $ES_OWNER")
        Or give this one its own:       devctl up --name $INSTANCE --dedicated-es, then devctl --name $INSTANCE seed"
  fi
  have_fixtures || { fixtures_hint; exit 1; }
  local rw_key
  rw_key="$(env_file_value "$RUNTIME/es_key_rw.env" GE_ELASTICSEARCH_API_KEY)"
  [[ -n "$rw_key" ]] || die "no ES key yet — run: devctl up"
  check_model_fixture_compat

  resolve_live

  # Seeding always writes to the *local* cluster — the seed services address it
  # directly and ignore GE_DEV_ES_URL, so there is no way for this to touch a
  # deployed one. Worth saying out loud, because the api is meanwhile reading
  # somewhere else and the data about to be loaded won't show up in a feed.
  if live_has es; then
    echo "devctl: note — seeding local Elasticsearch, but the api is reading" >&2
    echo "        $GE_DEV_ES_URL, so this data won't appear in feeds." >&2
  fi

  # megastream_ingest computes each post's ge_post_embedding by calling the
  # inference service, so the seed is only meaningful once that service has
  # actually loaded its models. seed-megastream can't depend_on it — whether it
  # runs at all is decided here, not in the compose file — so wait explicitly.
  # --wait blocks on the healthcheck, which probes /ready, not /health.
  if ! live_has inference; then
    echo "devctl: waiting for inference to be ready..."
    compose up -d --wait inference ||
      die "inference never became ready — see: devctl logs inference"
  fi

  echo "devctl: wiping previously seeded data..."
  compose run --rm seed-wipe
  echo "devctl: rebasing fixture timestamps..."
  compose run --rm seed-rebase
  echo "devctl: ingesting posts via megastream_ingest (first run compiles the Go binary)..."
  compose run --rm seed-megastream
  echo "devctl: loading likes and like counts..."
  compose run --rm seed-likes
  # status/feed/doctor compare against this to warn when the window drifts
  # out of the api's recency windows.
  printf 'GE_DEV_SEEDED_AT=%s\n' "$(date +%s)" >"$RUNTIME/seed.env"
  local persona api_running=0
  persona="$(env_file_value "$RUNTIME/probe.env" GE_PROBE_USER_DID)"
  # Restart the api so it picks up the new persona from .runtime/probe.env —
  # but only if it was already running, so `seed` never starts a service the
  # developer deliberately stopped.
  if service_running api; then
    export_api_es_env
    compose up -d --force-recreate api
    api_running=1
  fi

  echo "devctl: seed complete (persona: ${persona:-unset})."
  if [[ $api_running -eq 1 ]]; then
    echo "Try a feed:"
    echo "  devctl feed"
  else
    # Don't suggest a feed request with nothing to serve it.
    echo "The api isn't running — start it with: devctl up"
  fi
}

cmd_feed() {
  # Terminal feed viewer (issue #285): request getFeedSkeleton as the seeded
  # persona, hydrate each post from this environment's Elasticsearch, and print
  # the feed. Runs inside the api container, which already has every input the
  # viewer needs — the dev-session secret (so the api runs the full signed-in
  # path and records a snapshot for the transparency UI), the persona DID, the
  # ES read key, and the Firestore config for the per-post pipeline detail.
  #
  #   devctl feed
  #   devctl feed your-feed --user did:plc:... --limit 50 --pages 2
  #   devctl feed --json                 # raw getFeedSkeleton, the old output
  #
  # All arguments pass through to scripts/feed_view.py (feed defaults to
  # your-feed). See feed_view.py --help for the full flag set.
  service_running api ||
    die "the api isn't running — start it with: devctl up$(name_flag)"
  # The symptom of a stale seed is exactly this command coming back empty.
  warn_stale_seed
  compose_exec api pipenv run python scripts/feed_view.py "$@"
}

cmd_tunnel() {
  # `--live es` needs one of these open: the cluster sits behind an internal
  # load balancer with no address a container can dial. Runs in the foreground
  # and restarts itself, because kubectl port-forward drops connections
  # routinely and a silently dead tunnel looks like a broken environment.
  local env="${1:-$GE_DEV_LIVE_ENV}"
  case "$env" in
  stage | prod) ;;
  *) die "usage: devctl tunnel [stage|prod]" ;;
  esac

  command -v kubectl >/dev/null || die "kubectl is required for devctl tunnel"
  local ns="${GE_DEV_ES_NAMESPACE:-greenearth-$env}"
  local svc="${GE_DEV_ES_SERVICE:-svc/greenearth-es-internal-lb}"
  local port="${GE_DEV_ES_TUNNEL_PORT:-9200}"

  echo "devctl: tunneling $ns/$svc to localhost:$port (ctrl-c to stop)"
  echo "        then, in another shell: devctl up --live es --live-env $env"
  # The listener must be reachable from containers, which name the host as
  # host.docker.internal. Docker Desktop routes that to loopback, so the
  # default is fine there; on native Linux it's the bridge gateway, so the
  # tunnel has to listen wider: GE_DEV_ES_TUNNEL_BIND=0.0.0.0 (docs/remote.md).
  while true; do
    kubectl port-forward "$svc" "${port}:9200" -n "$ns" \
      --address "${GE_DEV_ES_TUNNEL_BIND:-127.0.0.1}" || true
    echo "devctl: tunnel dropped, reconnecting..." >&2
    sleep 2
  done
}

cmd_login() {
  # Signing in normally means completing Bluesky OAuth, which needs private
  # keys a credential-free environment doesn't have. The Auth emulator accepts
  # unsigned custom tokens, so we mint one for the seeded persona and hand it
  # to the app's own #/auth/finish route — the same entry point the real OAuth
  # callback redirects to. See firebase/mint_token.py.
  local persona token
  persona="${1:-$(env_file_value "$RUNTIME/probe.env" GE_PROBE_USER_DID)}"
  [[ -n "$persona" ]] ||
    die "no seeded persona found — run: devctl seed (or pass a did:plc:... explicitly)"

  token="$(python3 "$DEVENV_DIR/firebase/mint_token.py" "$persona")" || exit 1

  cat <<EOF
devctl: open this to sign in as the seeded persona ($persona):

  http://127.0.0.1:${FRONTEND_PORT}/#/auth/finish?token=${token}

The token is unsigned and only works against the Auth emulator. It expires in
an hour; re-run devctl login for a fresh one.
EOF
}

cmd_logs() {
  # Two modes on purpose. The default prints and exits, so `devctl logs api`
  # is a question you can ask and get an answer to. Following is opt-in with
  # -t, because a follow on an idle environment prints the backlog and then
  # sits there silently, which reads exactly like a hang.
  local follow=0
  local passthrough=()
  local have_tail=0
  local arg
  for arg in "$@"; do
    case "$arg" in
    -t | -f | --follow)
      follow=1
      ;;
    --tail | --tail=*)
      have_tail=1
      passthrough+=("$arg")
      ;;
    *)
      passthrough+=("$arg")
      ;;
    esac
  done
  # Only supply a default line count when the caller didn't pick one, so
  # `devctl logs --tail=500 api` works.
  [[ $have_tail -eq 1 ]] || passthrough=(--tail=100 ${passthrough[@]+"${passthrough[@]}"})
  if [[ $follow -eq 1 ]]; then
    compose logs -f ${passthrough[@]+"${passthrough[@]}"}
  else
    compose logs ${passthrough[@]+"${passthrough[@]}"}
  fi
}

cmd_status() {
  compose ps
  # 137 is SIGKILL, which here almost always means the kernel reclaimed memory
  # rather than anything about the service. `compose ps` shows the exit code
  # but not what it implies, and a stopped Elasticsearch is the version of
  # this environment failing that looks least like a memory problem.
  # `|| true`: with no killed container grep exits 1, which under `set -e`
  # would abort status before it prints the doc counts below.
  local killed
  killed="$(compose ps -a --format '{{.Service}} {{.Status}}' 2>/dev/null |
    { grep "Exited (137)" || true; } | awk '{print $1}' | tr '\n' ' ')"
  if [[ -n "$killed" ]]; then
    echo
    local restart="devctl up$(name_flag)"
    echo "** killed by the kernel, almost certainly out of memory: $killed" >&2
    echo "   restart with: $restart   (running instances: devctl ls)" >&2
  fi
  echo
  if share_es; then
    echo "elasticsearch shared from '$ES_OWNER':"
  fi
  if share_es || [[ -s "$RUNTIME/es_key_ro.env" ]]; then
    local alias
    for alias in posts likes inferences; do
      printf "%-12s %s docs\n" "$alias" \
        "$(es_curl "/${alias}/_count" | sed -n 's/.*"count":\([0-9]*\).*/\1/p')"
    done
  fi
  [[ "$GE_DEV_REPO_ROOT" == "$DEFAULT_REPO_ROOT" ]] ||
    echo "code         mounted from $GE_DEV_REPO_ROOT"
  local age
  age="$(seed_age_hours)"
  [[ -z "$age" ]] || echo "seeded       ${age}h ago"
  warn_stale_seed
}

# --- doctor -----------------------------------------------------------------
# One command that checks everything this environment needs and names the fix
# for whatever it finds — the first thing to run (human or agent) when the
# environment misbehaves, and the thing the troubleshooting doc points at
# before its symptom list.

DOCTOR_FAILS=0
DOCTOR_WARNS=0

d_ok() { printf '  ok    %s\n' "$1"; }
d_warn() {
  printf '  warn  %s\n' "$1"
  [[ -z "${2:-}" ]] || printf '        fix: %s\n' "$2"
  DOCTOR_WARNS=$((DOCTOR_WARNS + 1))
}
d_fail() {
  printf '  FAIL  %s\n' "$1"
  [[ -z "${2:-}" ]] || printf '        fix: %s\n' "$2"
  DOCTOR_FAILS=$((DOCTOR_FAILS + 1))
}

cmd_doctor() {
  echo "devctl doctor$(instance_label)"

  local docker_up=0
  if ! command -v docker >/dev/null; then
    d_fail "docker isn't installed" "https://docs.docker.com/get-docker/"
  elif ! docker info >/dev/null 2>&1; then
    d_fail "the docker daemon isn't running" "start Docker Desktop (or dockerd)"
  elif ! docker compose version >/dev/null 2>&1; then
    d_fail "docker compose v2 is missing" "install the compose plugin"
  else
    docker_up=1
    d_ok "docker $(docker info --format '{{.ServerVersion}}' 2>/dev/null), compose $(docker compose version --short 2>/dev/null)"
  fi

  local repo missing=""
  for repo in api ingex frontend inference-service; do
    [[ -e "$GE_DEV_REPO_ROOT/$repo/.git" ]] || missing+="$repo "
  done
  if [[ -n "$missing" ]]; then
    d_fail "sibling repos missing from $GE_DEV_REPO_ROOT: ${missing% }" \
      "clone them next to internal-tools (see docs/onboarding.md) or point at
             a working copy that has them: devctl up$(name_flag) --repo-root <dir>"
  else
    d_ok "sibling repos present under $GE_DEV_REPO_ROOT"
  fi

  if have_models; then
    d_ok "models $(models_tag)"
  else
    d_fail "no model artifacts in models/data/" "devctl fetch-models (or devctl setup)"
  fi
  if have_fixtures; then
    d_ok "fixture: $(python3 -c 'import json, sys
c = json.load(open(sys.argv[1]))["counts"]
print("%s posts / %s likes" % (format(c["posts"], ","), format(c["likes"], ",")))' \
      "$DEVENV_DIR/fixtures/data/manifest.json")"
  else
    d_fail "no fixture set in fixtures/data/" "devctl fetch-fixture"
  fi
  if have_models && have_fixtures; then
    if python3 "$DEVENV_DIR/models/check_compat.py" \
      "$DEVENV_DIR/models/data/manifest.json" \
      "$DEVENV_DIR/fixtures/data/manifest.json" >/dev/null 2>&1; then
      d_ok "models and fixture agree on the content encoder"
    else
      d_fail "models and fixture disagree on the content encoder" \
        "devctl fetch-models && devctl fetch-fixture, then devctl seed"
    fi
  fi

  if [[ $docker_up -eq 0 ]]; then
    doctor_summary
    return
  fi

  # --- the running stack, if any ---
  local running_svcs
  running_svcs="$(compose ps --status running --format '{{.Service}}' 2>/dev/null | sort | tr '\n' ' ')"
  if [[ -z "${running_svcs// /}" ]]; then
    d_warn "no containers running$(instance_label)" "devctl up$(name_flag)"
    doctor_summary
    return
  fi
  d_ok "running: ${running_svcs% }"

  local killed
  killed="$(compose ps -a --format '{{.Service}} {{.Status}}' 2>/dev/null |
    { grep "Exited (137)" || true; } | awk '{print $1}' | tr '\n' ' ')"
  [[ -z "${killed// /}" ]] ||
    d_fail "killed by the kernel, almost certainly out of memory: ${killed% }" \
      "devctl up$(name_flag) to restart; give Docker more memory or stop an instance (devctl ls)"
  check_memory_budget 2>&1 | sed 's/^/        /' || true

  if [[ "$GE_DEV_LIVE" == *es* ]]; then
    d_ok "the api reads LIVE Elasticsearch ($GE_DEV_LIVE_ENV) — local data checks skipped"
    doctor_summary
    return
  fi

  # Elasticsearch: reachable, keys minted, holding data.
  if share_es; then
    local code
    code="$(curl -s -o /dev/null -w '%{http_code}' --max-time 10 \
      -H "Authorization: ApiKey $(owner_ro_key)" \
      "http://127.0.0.1:$(owner_es_port)/_cluster/health" 2>/dev/null || true)"
    if [[ "$code" == "200" ]]; then
      d_ok "shared Elasticsearch (the '$ES_OWNER' instance's, port $(owner_es_port)) is answering"
    else
      d_fail "the '$ES_OWNER' instance's Elasticsearch isn't answering (HTTP ${code:-000})" \
        "start the owner: devctl up   (or run standalone: devctl up$(name_flag) --dedicated-es)"
    fi
  elif [[ ! -s "$RUNTIME/es_key_ro.env" ]]; then
    d_warn "no minted Elasticsearch keys yet" "devctl up$(name_flag)"
  else
    local health
    health="$(es_curl /_cluster/health 2>/dev/null | sed -n 's/.*"status":"\([a-z]*\)".*/\1/p')"
    case "$health" in
    green | yellow) d_ok "elasticsearch is $health" ;;
    *) d_fail "elasticsearch isn't answering on port $ES_PORT" \
      "devctl logs elasticsearch — if it exited 137, that's memory" ;;
    esac
  fi
  if service_running api; then
    local seed_fix="devctl seed"
    if share_es; then
      seed_fix="devctl seed   (on the '$ES_OWNER' instance, which owns the data)"
    fi

    local posts
    posts="$(es_curl /posts/_count 2>/dev/null | sed -n 's/.*"count":\([0-9]*\).*/\1/p')"
    if [[ -z "$posts" || "$posts" == "0" ]]; then
      d_warn "no posts indexed — feeds come back empty, not as errors" "$seed_fix"
    else
      d_ok "$posts posts indexed"
    fi

    local age
    age="$(seed_age_hours)"
    if [[ -n "$age" && "$age" -ge "$STALE_SEED_HOURS" ]]; then
      d_warn "seeded ${age}h ago — outside the api's 24h recency window, so recency feeds are empty" \
        "$seed_fix"
    elif [[ -n "$age" ]]; then
      d_ok "seeded ${age}h ago"
    fi

    local code
    code="$(curl -s -o /dev/null -w '%{http_code}' --max-time 10 "http://127.0.0.1:${API_PORT}/health" 2>/dev/null || true)"
    if [[ "$code" == "200" ]]; then
      d_ok "api answering on port $API_PORT"
    else
      d_warn "api isn't answering on port $API_PORT (HTTP ${code:-000})" \
        "first start installs dependencies — watch: devctl logs -t api"
    fi
  fi

  doctor_summary
}

doctor_summary() {
  echo
  if [[ $DOCTOR_FAILS -gt 0 ]]; then
    local warns=""
    [[ $DOCTOR_WARNS -eq 0 ]] || warns=" and $DOCTOR_WARNS warning(s)"
    die "$DOCTOR_FAILS problem(s)$warns found"
  elif [[ $DOCTOR_WARNS -gt 0 ]]; then
    echo "devctl: $DOCTOR_WARNS warning(s), nothing fatal"
  else
    echo "devctl: everything checks out"
  fi
}

cmd_nuke() {
  # The owner's cluster holds the data every sharer is serving, so destroying
  # it out from under them would look like several environments breaking at
  # once. Refuse while any sharer's runtime is still on disk; GE_DEV_FORCE_NUKE
  # is the escape hatch for when that's genuinely the intent.
  if [[ "$INSTANCE" == "$ES_OWNER" && -z "${GE_DEV_FORCE_NUKE:-}" ]]; then
    local sharers
    sharers="$(sharers_of_owner)"
    [[ -z "$sharers" ]] || die "these instances share this one's Elasticsearch: $sharers
        Nuking it takes their data with it. Either nuke them first
        (devctl nuke --name <name>), give each its own cluster
        (devctl up --name <name> --dedicated-es), or force it:
        GE_DEV_FORCE_NUKE=1 devctl nuke"
  fi
  compose down -v --remove-orphans
  # Volumes are namespaced by compose project, and the runtime directory and
  # derived Firebase config are named after the instance — so this destroys
  # only this instance's data, whatever else is running.
  rm -rf "$RUNTIME"
  rm -f "$GE_DEV_REPO_ROOT/frontend/$GE_DEV_FIREBASE_CONFIG"
  echo "devctl: all containers, data volumes, and runtime state removed$(instance_label)."
}

cmd_es() {
  # Query this instance's Elasticsearch without having to find its port or its
  # key first — both move per instance, and the cluster has security on, so
  # the obvious `curl localhost:9200/...` just returns a 401.
  #
  #   devctl es /posts/_count
  #   devctl es '/posts/_search?size=1&pretty'
  #   devctl es /posts/_search -X POST -H 'Content-Type: application/json' -d '{...}'
  #
  # Read-only: this is the same key the api reads with.
  [[ $# -gt 0 ]] || die "usage: devctl es <path> [curl args...]
        e.g. devctl es /posts/_count"
  local path="$1"
  shift
  es_curl "$path" "$@"
  echo
}

cmd_ports() {
  # --ssh prints ready-made port-forwarding flags for reaching this instance
  # from another machine, one -L per published port, same number both ends:
  #   ssh -N $(devctl ports --ssh) devbox        # run where devctl runs
  # See docs/remote.md.
  if [[ "${1:-}" == "--ssh" ]]; then
    local flags="" port
    for port in "$FRONTEND_PORT" "$API_PORT" "$ES_PORT" "$FIRESTORE_PORT" \
      "$AUTH_PORT" "$FUNCTIONS_PORT" "$FIREBASE_UI_PORT" "$GE_DEV_PORT_FIREBASE_UI_WS"; do
      flags+="-L ${port}:127.0.0.1:${port} "
    done
    echo "${flags% }"
    return
  fi
  # With a service name, print just the number, so it can be substituted
  # straight into a command:
  #   curl http://127.0.0.1:$(devctl ports api --name alpha)/health
  if [[ $# -gt 0 ]]; then
    local name="$1"
    # The service is called elasticsearch everywhere else in this tool; the
    # port variable has always been the shorter GE_DEV_PORT_ES.
    case "$name" in
    elasticsearch) name=es ;;
    auth) name=firebase_auth ;;
    ui) name=firebase_ui ;;
    esac
    local var="GE_DEV_PORT_$(echo "$name" | tr '[:lower:]-' '[:upper:]_')"
    [[ -n "${!var:-}" ]] || die "no published port for '$1' (try: devctl ports)"
    echo "${!var}"
    return
  fi
  cat <<EOF
instance      $INSTANCE (compose project $GE_DEV_NAME, offset $GE_DEV_PORT_OFFSET)
api           $API_PORT
elasticsearch $ES_PORT
frontend      $FRONTEND_PORT
firestore     $FIRESTORE_PORT
firebase_auth $AUTH_PORT
functions     $FUNCTIONS_PORT
firebase_ui   $FIREBASE_UI_PORT
EOF
}

cmd_ls() {
  # Every instance that exists on disk, whether or not it's running — a
  # stopped instance still owns its ports and its volumes, which is exactly
  # what someone asking "what's here?" needs to know.
  local running=""
  if docker info >/dev/null 2>&1; then
    running="$(running_projects)"
  fi

  printf "%-14s %-9s %-7s %-7s %-9s %s\n" NAME STATE OFFSET API FRONTEND ROOT
  local name offset api frontend found=0
  while read -r name offset api frontend; do
    [[ -n "$name" ]] || continue
    found=1
    local state="stopped"
    [[ " $running " == *" ge-$name "* ]] && state="running"
    # The recorded repo root, shown only when it isn't the shared default —
    # that's the row where "which checkout is this instance on?" has a
    # surprising answer.
    local rdir="$DEVENV_DIR/.runtime" root
    [[ "$name" == "dev" ]] || rdir="$DEVENV_DIR/.runtime.$name"
    root="$(env_file_value "$rdir/repo_root.env" GE_DEV_REPO_ROOT)"
    [[ -n "$root" && "$root" != "$DEFAULT_REPO_ROOT" ]] || root="-"
    printf "%-14s %-9s %-7s %-7s %-9s %s\n" "$name" "$state" "$offset" "$api" "$frontend" "$root"
  done < <(python3 -c "
import sys
from pathlib import Path
sys.path.insert(0, '$DEVENV_DIR')
import ports
devenv = Path('$DEVENV_DIR')
import os
bases = ports.resolve_bases(dict(os.environ))
for name, offset in ports.list_instances(devenv):
    p = ports.ports_for(offset, bases)
    print(name, offset, p['API'], p['FRONTEND'])")
  [[ $found -eq 1 ]] || echo "(no instances yet — devctl up)"
}

cmd_exec() {
  # One entrypoint for running things inside the environment (issue api#283),
  # so a coding agent's sandbox can allow `devctl exec` instead of every
  # command that might ever need to run in a container:
  #
  #   devctl exec api pipenv run pytest
  #   devctl exec --name alpha api pipenv run ruff check .
  #
  # --name is parsed here rather than globally because everything after the
  # service name belongs to the command being run and must pass through
  # untouched — including flags that happen to be spelled like ours.
  while [[ "${1:-}" == "--name" ]]; do
    [[ -n "${2:-}" ]] || die "--name needs an instance name"
    set_instance "$2"
    shift 2
  done
  resolve_ports read
  local service="${1:-}"
  shift || true
  [[ -n "$service" && $# -gt 0 ]] ||
    die "usage: devctl exec [--name <instance>] <service> <command>...
        e.g. devctl exec api pipenv run pytest"

  service_running "$service" ||
    die "service '$service' isn't running$(instance_label) — start it with: devctl up$(name_flag)"

  compose_exec "$service" "$@"
}

cmd_restart() {
  # Recreate rather than `compose restart`, so a service picks up changed
  # environment (a new ES key, a different live target) and not just changed
  # code. --no-deps keeps it to the named services: restarting the api should
  # not bounce Elasticsearch underneath everything else.
  [[ $# -gt 0 ]] || die "usage: devctl restart <service>... (whole stack: devctl up)"
  check_docker
  resolve_live
  export_api_es_env
  compose up -d --no-deps --force-recreate "$@"
  echo "devctl: restarted$(instance_label): $*"
}

# The test suites, and how each runs. api/inference/frontend run in the live
# container, where their dependencies are already installed; ingex is Go with
# no long-running service, so it gets an ephemeral container over the same
# bind-mounted source and shared caches the ingest uses. `devctl exec` covers
# anything finer (a single file, a -k filter, -v) — see `devctl help`.
TEST_SUITES="api inference ingex frontend"

run_test_suite() {
  case "$1" in
  api) compose_exec api pipenv run pytest ;;
  inference) compose_exec inference pipenv run pytest ;;
  frontend) compose_exec frontend npm run test:unit ;;
  ingex)
    local t=""
    [[ -t 1 ]] && t="-t" || true
    docker run --rm $t \
      -v "$GE_DEV_REPO_ROOT/ingex/ingest:/src" -w /src \
      -v ge-dev-gomod:/go/pkg/mod -v ge-dev-gocache:/root/.cache/go-build \
      "$GO_IMAGE" go test -race ./...
    ;;
  esac
}

cmd_test() {
  # Run a repo's test suite inside the environment, or all of them with no
  # argument. The point is a first-class, allowlistable entry point for "run
  # the tests" that doesn't require knowing each repo's runner.
  #
  #   devctl test              # every suite
  #   devctl test api          # just one
  #   devctl --name alpha test api
  check_docker
  ensure_go_caches

  local suites=("$@")
  [[ ${#suites[@]} -gt 0 ]] || suites=($TEST_SUITES)

  local s
  for s in "${suites[@]}"; do
    case " $TEST_SUITES " in
    *" $s "*) ;;
    *) die "unknown test suite: $s (choose from: $TEST_SUITES, or omit for all)" ;;
    esac
  done

  # The container suites need the stack up. Check them all first, so a bare
  # `devctl test` with nothing running says so once rather than dying on the
  # first suite after ingex has already run.
  local need_up=()
  for s in "${suites[@]}"; do
    case "$s" in
    api | inference | frontend)
      service_running "$s" || need_up+=("$s")
      ;;
    esac
  done
  if [[ ${#need_up[@]} -gt 0 ]]; then
    die "these need the stack running: ${need_up[*]}
        start it:  devctl up$(name_flag)
        (ingex tests need nothing running: devctl test ingex)"
  fi

  local failed=()
  for s in "${suites[@]}"; do
    echo
    echo "devctl: ===== $s ====="
    run_test_suite "$s" || failed+=("$s")
  done

  echo
  [[ ${#failed[@]} -eq 0 ]] || die "test failures: ${failed[*]}"
  echo "devctl: all passed (${suites[*]})"
}

usage() {
  cat <<EOF
devctl — Green Earth local dev environment

Usage: devctl [--name <instance>] <command> [args]

Setup (first run):
  bootstrap        fresh clone to a working, seeded environment in one command
                   (setup + fetch-fixture + up + seed; resumes if interrupted)
  setup            check prerequisites, build/pull images, download models,
                   install inference-service's dependencies
  fetch-fixture    download the published fixture set (no account or auth needed)
  fetch-models     download the pinned trained models (no account or auth needed)

Run the stack:
  up               start the stack (ES + Firebase emulators + inference + api)
                     --live es,inference,perspective  use deployed services
                     --live-env stage|prod            which deployment (default stage)
                     --with-ingest                    also ingest live posts+likes
                       (--with-megastream / --with-jetstream for one half)
                     --watch                          reload api/inference on edit
                     --dedicated-es                   own Elasticsearch, not shared
                     --repo-root <dir>                mount checkouts from another
                       working copy (sticks per instance; default: this repo's parent)
  seed             load fixtures: rebase timestamps, ingest posts, load likes
  restart <svc>    recreate one service, picking up code and config changes
  down             stop containers (data volumes survive)
  nuke             stop and delete everything (volumes, minted keys, seed state)

Work with it:
  test [svc]       run a repo's tests inside the env, or all with no arg
                     (api, inference, ingex, frontend)
  exec <svc> ...   run any command in a service (e.g. exec api pipenv run pytest)
  feed [feed]      view a hydrated feed in the terminal (default: your-feed;
                   --user <did>, --limit, --pages, --json for raw skeleton)
  es <path>        query this instance's Elasticsearch (read-only key, e.g.
                   devctl es /posts/_count)
  login [did]      print a sign-in URL for the frontend as the seeded persona
  status           container status + index doc counts + seed age
  doctor           check everything and name the fix — run this first when
                   the environment misbehaves
  logs [svc...]    print recent logs and exit (-t follows instead)

Instances & ports:
  ls               every instance on this machine, and whether it's running
  ports [svc]      this instance's published ports (one number with a service;
                   --ssh prints port-forwarding flags for remote use)
  tunnel [env]     port-forward a deployed Elasticsearch, for --live es

Instances
  --name <n> runs a second environment with its own containers, volumes and
  ports; it works on every command and defaults to "dev". A named instance
  reads dev's Elasticsearch (the memory-hungry part), so it's read-only against
  that data — seed dev, or pass --dedicated-es to give it its own cluster.
  Give each instance its own working copy (e.g. git worktrees) with
  'up --repo-root <dir>' so parallel agents edit parallel code — the choice is
  remembered per instance and shown by devctl ls. See docs/agents.md.

Fixtures & models
  fetch-fixture and fetch-models download published sets — no account needed.
  Roll your own with fixtures/generate_sample.py (two modes) and
  fixtures/publish_fixture.sh; maintainers publish models with
  models/publish_models.sh (from the prod bucket).

Configuration (devenv.local.env, gitignored)
  Live-service keys:   GE_DEV_ES_API_KEY, GE_DEV_INFERENCE_API_KEY,
                       GE_PERSPECTIVE_API_KEY
  Stick a live choice: GE_DEV_LIVE, GE_DEV_LIVE_ENV (else a bare 'up' is all-local)
  Other overrides:     ports (GE_DEV_PORT_*), ES heap (GE_DEV_ES_HEAP),
                       repo root (GE_DEV_REPO_ROOT)
EOF
}

# ---------------------------------------------------------------------------

cmd="${1:-}"
[[ -n "$cmd" ]] && shift || true

# Ports have to be known before most commands run, and `up` is the only one
# allowed to claim a block: everywhere else, an instance that has no ports
# recorded doesn't exist, and saying so beats acting on the wrong one.
# `exec` resolves its own, after parsing the --name that may follow it.
case "$cmd" in
setup | fetch-fixture | fetch-models | ls | exec | "" | help | -h | --help) ;;
up | bootstrap) ;; # allocate inside cmd_up, after its flags are parsed
*) resolve_ports read ;;
esac

case "$cmd" in
setup) cmd_setup "$@" ;;
bootstrap) cmd_bootstrap "$@" ;;
fetch-fixture) cmd_fetch_fixture "$@" ;;
fetch-models) cmd_fetch_models "$@" ;;
up) cmd_up "$@" ;;
tunnel) cmd_tunnel "$@" ;;
seed) cmd_seed "$@" ;;
feed) cmd_feed "$@" ;;
login) cmd_login "$@" ;;
status | ps) cmd_status "$@" ;;
doctor) cmd_doctor "$@" ;;
logs) cmd_logs "$@" ;;
exec) cmd_exec "$@" ;;
test) cmd_test "$@" ;;
es) cmd_es "$@" ;;
restart) cmd_restart "$@" ;;
ports) cmd_ports "$@" ;;
ls | instances) cmd_ls "$@" ;;
down)
  # Stopping the owner leaves any sharer's api reading a cluster that's no
  # longer there. Data survives (down keeps volumes), but say so.
  if [[ "$INSTANCE" == "$ES_OWNER" ]]; then
    sharers="$(sharers_of_owner)"
    [[ -z "$sharers" ]] ||
      echo "devctl: note — these instances read this one's Elasticsearch: $sharers" >&2
  fi
  compose down
  rm -f "$GE_DEV_REPO_ROOT/frontend/$GE_DEV_FIREBASE_CONFIG"
  ;;
nuke) cmd_nuke "$@" ;;
"" | help | -h | --help) usage ;;
*) die "unknown command: $cmd (try: devctl help)" ;;
esac
